@model LOCPS.Common.PagedResult<LOCPS.Models.LoanApplication>
@{
    ViewData["Title"] = "Loan Officer Dashboard";
    ViewData["CurrentStep"] = "Applications";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Assigned Applications</h1>
            <p class="text-muted">Review applications, process KYC, verify documents, and perform credit checks.</p>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">App ID</th>
                        <th>Applicant</th>
                        <th>Product</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date Submitted</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.ApplicationNumber</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-primary-subtle text-primary me-2">
                                            @item.Customer.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.Customer.FullName</div>
                                            <div class="small text-muted">@item.Customer.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Product.ProductName</td>
                                <td class="fw-semibold">&#8377; @item.RequestedAmount.ToString("N0")</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            LOCPS.Enums.ApplicationStatus.Submitted => "bg-secondary",
                                            LOCPS.Enums.ApplicationStatus.KYCPending => "bg-warning text-dark",
                                            LOCPS.Enums.ApplicationStatus.KYCVerified => "bg-info text-dark",
                                            LOCPS.Enums.ApplicationStatus.UnderReview => "bg-primary",
                                            LOCPS.Enums.ApplicationStatus.Approved => "bg-success",
                                            LOCPS.Enums.ApplicationStatus.Rejected => "bg-danger",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3 py-2 shadow-sm">
                                        @item.Status.ToString()
                                    </span>
                                </td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Loan" asp-action="Details" asp-route-id="@item.ApplicationId" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">
                                        Review <i class="fa-solid fa-arrow-right ms-1"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-inbox fa-3x mb-3 text-light"></i>
                                <p class="mb-0">No assigned applications found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }
</style>
