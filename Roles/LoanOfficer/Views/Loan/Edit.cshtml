@{
    ViewData["Title"] = "Adjust Loan Application";
    ViewData["CurrentStep"] = "Loan Application";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Edit Loan Application</h1>
        <p class="text-muted">Revise requested details for loan application #LOC-9844-32.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Adjust Financial Terms & Product</h5>
            </div>
            
            <div class="card-body">
                <form id="editLoanForm" onsubmit="handleEditSubmit(event)">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Applicant Name</label>
                            <input type="text" class="form-control py-2 bg-light border-0 shadow-none" value="Rajesh Kumar" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Select Loan Product <span class="text-danger">*</span></label>
                            <select class="form-select py-2 shadow-none" id="wizardProduct" required>
                                <option value="Home Purchase Loan" data-rate="8.5" selected>Home Purchase Loan (8.5% p.a.)</option>
                                <option value="Personal Express Loan" data-rate="12.0">Personal Express Loan (12.0% p.a.)</option>
                                <option value="Commercial Equipment Loan" data-rate="10.5">Commercial Equipment Loan (10.5% p.a.)</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-semibold text-muted small d-flex justify-content-between">
                                <span>Requested Loan Amount (INR)</span>
                                <span class="fw-bold text-primary" id="amountValDisplay">₹ 4,500,000</span>
                            </label>
                            <input type="range" class="range-slider" id="loanAmountSlider" min="100000" max="10000000" step="50000" value="4500000" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small d-flex justify-content-between">
                                <span>Interest Rate (% p.a.)</span>
                                <span class="fw-bold text-primary" id="rateValDisplay">8.5%</span>
                            </label>
                            <input type="range" class="range-slider" id="loanRateSlider" min="5" max="25" step="0.1" value="8.5" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small d-flex justify-content-between">
                                <span>Tenure (Months)</span>
                                <span class="fw-bold text-primary" id="tenureValDisplay">180 Months</span>
                            </label>
                            <input type="range" class="range-slider" id="loanTenureSlider" min="12" max="360" step="12" value="180" />
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" id="btnEditSubmit" class="btn btn-primary px-4 py-2" style="border-radius: var(--radius-md);">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Update Application
                        </button>
                        <a href="/Loan" class="btn btn-light border px-4 py-2" style="border-radius: var(--radius-md);">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Info & EMI Estimator Column -->
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm emi-calculator-card">
            <div class="card-header border-bottom py-3">
                <h5 class="card-title fw-bold text-white m-0"><i class="fa-solid fa-calculator me-2"></i> Revised Loan EMI</h5>
            </div>
            <div class="card-body">
                <div class="text-center py-3">
                    <span class="small text-white-50 d-block mb-1">Estimated Monthly Installment</span>
                    <h2 class="fw-extrabold text-white m-0" id="emiVal">₹ 44,312</h2>
                </div>
                
                <div class="border-top pt-3 mt-3">
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Principal Amount</span>
                        <span class="fw-semibold" id="emiPrincipal">₹ 4,500,000</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Estimated Interest Payable</span>
                        <span class="fw-semibold text-warning" id="emiInterest">₹ 3,476,160</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-white-50">Total Amount Payable</span>
                        <span class="fw-semibold text-info" id="emiTotal">₹ 7,976,160</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/emi-calculator.js"></script>
    <script src="~/js/loan-wizard.js"></script>
    <script>
        function handleEditSubmit(e) {
            e.preventDefault();
            const productSelect = document.getElementById("wizardProduct");
            const amountSlider = document.getElementById("loanAmountSlider");
            const rateSlider = document.getElementById("loanRateSlider");
            const tenureSlider = document.getElementById("loanTenureSlider");

            if (productSelect) localStorage.setItem("locps_loan_type", productSelect.value);
            if (amountSlider) localStorage.setItem("locps_loan_amount", amountSlider.value);
            if (rateSlider) localStorage.setItem("locps_loan_rate", rateSlider.value);
            if (tenureSlider) localStorage.setItem("locps_loan_tenure", tenureSlider.value);

            const btn = document.getElementById("btnEditSubmit");
            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Saving...`;

            setTimeout(() => {
                showToast("Success", "Loan application LOC-9844-32 has been updated successfully.", "success");
                setTimeout(() => {
                    window.location.href = "/Loan";
                }, 1200);
            }, 1000);
        }
    </script>
}
