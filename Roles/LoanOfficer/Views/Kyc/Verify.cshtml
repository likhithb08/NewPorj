@{
    ViewData["Title"] = "KYC Document Verification";
    ViewData["CurrentStep"] = "KYC Verification";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">KYC Compliance Check</h1>
        <p class="text-muted">Perform mandatory identity checks using external integrations (simulated).</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <!-- Left column - Check list -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Mandatory Verification Items</h5>
            </div>
            
            <div class="card-body pt-0">
                <!-- Checklist Item 1 -->
                <div class="py-3 border-bottom d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center border-3 text-muted" id="panStatusCircle" style="width: 38px; height: 38px; font-weight: 700; border-style: solid;">
                            <i class="fa-solid fa-address-card" id="panIcon"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">PAN Card Verification</div>
                            <span class="text-muted small">Verifies name and existence from Income Tax database.</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge-status badge-status-pending" id="panBadge">Pending</span>
                        <button class="btn btn-sm btn-outline-primary" id="btnVerifyPan" onclick="verifyPanCard()">Verify PAN</button>
                    </div>
                </div>

                <!-- Checklist Item 2 -->
                <div class="py-3 border-bottom d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center border-3 text-muted" id="aadhaarStatusCircle" style="width: 38px; height: 38px; font-weight: 700; border-style: solid;">
                            <i class="fa-solid fa-fingerprint" id="aadhaarIcon"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Aadhaar Bio-metrics Match</div>
                            <span class="text-muted small">Sends OTP confirmation code to registered mobile.</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge-status badge-status-pending" id="aadhaarBadge">Pending</span>
                        <div class="d-flex gap-1" id="aadhaarActions">
                            <button class="btn btn-sm btn-outline-primary" id="btnSendOtp" onclick="sendAadhaarOtp()">Send OTP</button>
                        </div>
                    </div>
                </div>

                <!-- Checklist Item 3 -->
                <div class="py-3 border-bottom d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center border-3 text-muted" id="addrStatusCircle" style="width: 38px; height: 38px; font-weight: 700; border-style: solid;">
                            <i class="fa-solid fa-house-chimney" id="addrIcon"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Address Matching checks</div>
                            <span class="text-muted small">Cross-references address with electricity/water bills.</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge-status badge-status-pending" id="addrBadge">Pending</span>
                        <button class="btn btn-sm btn-outline-primary" id="btnVerifyAddr" onclick="verifyAddress()">Run Address Match</button>
                    </div>
                </div>
                
                <!-- Complete Button -->
                <div class="mt-4 pt-3 text-end d-none" id="submitKycWrapper">
                    <button class="btn btn-success px-4 py-2" id="btnSubmitKyc" onclick="submitKycCompliance()">
                        <i class="fa-solid fa-circle-check me-2"></i> Submit KYC Approval & Continue
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column - Applicant Profile Context -->
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold text-dark m-0">Applicant Verification Info</h6>
            </div>
            <div class="card-body pt-0">
                <ul class="list-group list-group-flush" style="font-size: 0.85rem;">
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Applicant Name</div>
                        <div class="fw-bold mt-1 text-dark">Rajesh Kumar</div>
                    </li>
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">PAN Card Number</div>
                        <div class="fw-semibold text-secondary mt-1">BKDPK7849D</div>
                    </li>
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Registered Address</div>
                        <div class="fw-semibold text-secondary mt-1">#45, 2nd Main, JP Nagar, Bangalore - 560078</div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/kyc.js"></script>
}
