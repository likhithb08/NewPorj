@{
    ViewData["Title"] = "Credit Evaluation & Scoring";
    ViewData["CurrentStep"] = "Credit Evaluation";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Credit Evaluation Dashboard</h1>
        <p class="text-muted">Inspect automated credit score analysis, debt indicators, and bureau matches.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row g-4">
    <!-- Left Column - Score Gauge and breakdown -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm text-center py-4 mb-4">
            <h5 class="fw-bold text-dark mb-3">Bureau Credit Score (CIBIL)</h5>
            
            <!-- Animated SVG Gauge -->
            <div class="score-gauge-container mb-3" style="width: 220px; height: 110px;">
                <svg width="220" height="220" class="position-absolute" style="top: 0; left: 0;">
                    <!-- Gray background arc -->
                    <path d="M 20 110 A 90 90 0 0 1 200 110" fill="none" stroke="#E5E7EB" stroke-width="16" stroke-linecap="round" />
                    <!-- Colored progress arc -->
                    <path d="M 20 110 A 90 90 0 0 1 200 110" fill="none" id="gaugeProgressArc" stroke="url(#gaugeGradient)" stroke-width="16" stroke-linecap="round" stroke-dasharray="282.7" stroke-dashoffset="282.7" style="transition: stroke-dashoffset 2s ease-out;" />
                    
                    <defs>
                        <linearGradient id="gaugeGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="#EF4444" /> <!-- Red -->
                            <stop offset="50%" stop-color="#F59E0B" /> <!-- Amber -->
                            <stop offset="100%" stop-color="#10B981" /> <!-- Green -->
                        </linearGradient>
                    </defs>
                </svg>
                <div class="score-gauge-val" id="scoreValue">300</div>
            </div>
            <div class="score-gauge-lbl" id="riskRatingText">Evaluating...</div>
            <span class="text-muted small mt-2">Bureau Pull Timestamp: Just Now</span>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold text-dark m-0">Bureau Score Ranges</h6>
            </div>
            <div class="card-body pt-0" style="font-size: 0.85rem;">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted"><i class="fa-solid fa-circle text-success me-1"></i> Excellent</span>
                    <span class="fw-semibold">750 - 900</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted"><i class="fa-solid fa-circle text-info me-1"></i> Good</span>
                    <span class="fw-semibold">700 - 749</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted"><i class="fa-solid fa-circle text-warning me-1"></i> Fair</span>
                    <span class="fw-semibold">600 - 699</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted"><i class="fa-solid fa-circle text-danger me-1"></i> Poor</span>
                    <span class="fw-semibold">300 - 599</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column - Risk Factors & Rule engine -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Core Risk Metrics Analysis</h5>
            </div>
            <div class="card-body pt-0">
                <!-- Metric 1: Debt to Income -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted fw-semibold">Debt-to-Income Ratio (DTI)</span>
                        <span class="fw-bold text-success">32.4% (Optimal)</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 32.4%;" aria-valuenow="32.4" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <span class="text-muted small d-block mt-1" style="font-size: 0.75rem;">Threshold: Safe < 40%, Warning 40%-50%, Critical > 50%</span>
                </div>

                <!-- Metric 2: Repayment History -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted fw-semibold">Repayment Track Record</span>
                        <span class="fw-bold text-success">98.5% On-Time</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 98.5%;" aria-valuenow="98.5" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <!-- Metric 3: Credit Utilization -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted fw-semibold">Credit Card Utilization Rate</span>
                        <span class="fw-bold text-warning">48.2% (Moderate)</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 48.2%;" aria-valuenow="48.2" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Automated Rules Card -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Rule Validation Engine</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="p-3 bg-light rounded" style="border-radius: var(--radius-md);">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold small text-dark"><i class="fa-solid fa-calculator me-1"></i> Scoring Engine Evaluation</span>
                            <span class="badge bg-warning rounded" id="ruleEngineStatus">Awaiting Execution</span>
                        </div>
                        <p class="small text-muted mb-0" id="ruleEngineDetails">Rule calculations will verify credit thresholds and calculate final pricing tier eligibility.</p>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-primary py-2 px-3" id="btnRunRules" onclick="runRulesEngine()">
                            <i class="fa-solid fa-play me-2"></i> Run Scoring Rules
                        </button>
                        
                        <button class="btn btn-success py-2 px-4 d-none" id="btnContinueCredit" onclick="continueWorkflow()">
                            Save & Continue <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/credit-evaluation.js"></script>
}
