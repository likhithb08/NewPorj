@model LOCPS.Models.Approval

@{
    ViewData["Title"] = "Loan Rejected";
    ViewData["CurrentStep"] = "Approve/Reject";
}

<div class="row mb-4">
    <div class="col-12 text-center py-4">
        <div class="bg-danger text-white rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; font-size: 2.5rem;">
            <i class="fa-solid fa-xmark"></i>
        </div>
        <h1 class="h2 fw-bold text-dark mb-2">Loan Application Rejected</h1>
        <p class="text-muted">Application <strong>@(Model.Application?.ApplicationNumber ?? $"LOC-{Model.ApplicationId}")</strong> has been declined. The applicant will be notified with reasons.</p>
        <div class="d-flex gap-2 justify-content-center mt-4">
            <a href="/Dashboard" class="btn btn-primary px-4 py-2">
                Back to Dashboard
            </a>
        </div>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="card border-0 shadow-sm mx-auto" style="max-width: 640px;">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold m-0">Rejection Notice Details</h5>
    </div>
    <div class="card-body pt-0">
        <ul class="list-group list-group-flush" style="font-size: 0.875rem;">
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Application ID</span>
                <span class="fw-bold">@(Model.Application?.ApplicationNumber ?? $"LOC-{Model.ApplicationId}")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Applicant</span>
                <span class="fw-semibold">@(Model.Application?.Customer?.FullName ?? "Rajesh Kumar")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Rejection Reason</span>
                <span class="fw-bold text-danger">@(Model.RejectionReason ?? "Credit Policy Violation")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Rejected By</span>
                <span class="fw-semibold">@(Model.Approver?.FullName ?? "Underwriter")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Loan Product</span>
                <span class="fw-semibold">@(Model.Application?.Product?.ProductName ?? "Home Purchase Loan")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Requested Amount</span>
                <span class="fw-bold text-danger">₹ @(Model.Application?.RequestedAmount.ToString("N0") ?? "—")</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Rejection Date</span>
                <span class="fw-semibold">@Model.ApprovalDate.ToString("MMMM dd, yyyy")</span>
            </li>
            @if (!string.IsNullOrEmpty(Model.Comments))
            {
                <li class="list-group-item px-0 py-3">
                    <span class="text-muted small">Underwriter remarks:</span>
                    <p class="mb-0 text-muted small italic mt-1 bg-light p-2 rounded">@Model.Comments</p>
                </li>
            }
        </ul>
    </div>
</div>
