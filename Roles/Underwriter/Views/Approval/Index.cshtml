@model LOCPS.Common.PagedResult<LOCPS.Models.LoanApplication>
@using LOCPS.Enums

@{
    ViewData["Title"] = "Underwriter Review Queue";
    ViewData["CurrentStep"] = "Underwriter Review";

    string StatusClass(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Submitted => "pending",
        ApplicationStatus.KYCPending => "pending",
        ApplicationStatus.KYCVerified => "processing",
        ApplicationStatus.UnderReview => "processing",
        ApplicationStatus.CreditEvaluated => "processing",
        ApplicationStatus.Approved => "approved",
        ApplicationStatus.Disbursed => "approved",
        ApplicationStatus.Closed => "approved",
        ApplicationStatus.Rejected => "rejected",
        _ => "pending"
    };
}

<div class="row mb-4">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Underwriter Review Queue</h1>
        <p class="text-muted mb-0">Applications credit-scored and awaiting your decision.</p>
    </div>
    <div class="col-sm-6 text-end">
        <span class="badge bg-primary fs-6 px-3 py-2">@Model.TotalCount pending</span>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="card-title fw-bold m-0">
            <i class="fa-solid fa-signature me-2 text-primary"></i>Applications Awaiting Decision
        </h5>
    </div>
    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Application ID</th>
                            <th>Customer</th>
                            <th>Product</th>
                            <th>Requested Amount</th>
                            <th>Annual Income</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Items)
                        {
                            <tr>
                                <td><span class="fw-bold text-primary">@app.ApplicationNumber</span></td>
                                <td>@(app.Customer?.FullName ?? "—")</td>
                                <td class="text-muted small">@(app.Product?.ProductName ?? "—")</td>
                                <td class="fw-semibold">₹ @app.RequestedAmount.ToString("N0")</td>
                                <td class="text-muted small">₹ @app.AnnualIncome.ToString("N0")</td>
                                <td><span class="badge-status badge-status-@StatusClass(app.Status)">@app.Status</span></td>
                                <td class="text-muted small">@app.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-end">
                                    <a asp-controller="Approval" asp-action="Review" asp-route-id="@app.ApplicationId"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-gavel me-1"></i>Review
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white border-0 py-3">
                    @await Html.PartialAsync("_Pagination", Model)
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-check-double text-success fs-2 mb-3 d-block"></i>
                <p class="text-muted fw-semibold mb-1">No applications pending decision.</p>
                <p class="text-muted small">All credit-scored applications have been reviewed.</p>
            </div>
        }
    </div>
</div>
