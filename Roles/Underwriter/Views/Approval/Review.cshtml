@model LOCPS.Models.LoanApplication
@using LOCPS.Enums
@using LOCPS.Models

@{
    ViewData["Title"] = "Underwriter Review";
    ViewData["CurrentStep"] = "Underwriter Review";
    
    var kyc = ViewBag.Kyc as Kyc;
    var documents = ViewBag.Documents as IEnumerable<Document> ?? Enumerable.Empty<Document>();
    var creditEval = ViewBag.CreditEvaluation as CreditEvaluation;
    var auditLogs = ViewBag.AuditLogs as IEnumerable<Auditlog> ?? Enumerable.Empty<Auditlog>();
    
    string StatusClass(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Submitted => "pending",
        ApplicationStatus.KYCPending => "pending",
        ApplicationStatus.KYCVerified => "processing",
        ApplicationStatus.UnderReview => "processing",
        ApplicationStatus.CreditEvaluated => "processing",
        ApplicationStatus.Approved => "approved",
        ApplicationStatus.Disbursed => "approved",
        ApplicationStatus.Closed => "approved",
        ApplicationStatus.Rejected => "rejected",
        _ => "pending"
    };

    string KycClass(KycStatus s) => s switch
    {
        KycStatus.Verified => "approved",
        KycStatus.Rejected => "rejected",
        _ => "pending"
    };

    string DocClass(DocumentStatus s) => s switch
    {
        DocumentStatus.Verified => "approved",
        DocumentStatus.Rejected => "rejected",
        _ => "pending"
    };
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Underwriter Decision Desk</h1>
        <p class="text-muted">Final review panel for loan application <strong>@Model.ApplicationNumber</strong> — @Model.Customer.FullName.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Applicant & Loan Overview -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold m-0">Applicant & Loan Overview</h5></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="bg-light p-3 rounded text-center">
                            <div class="text-muted small">Requested Amount</div>
                            <div class="fw-bold text-dark mt-1">₹ @Model.RequestedAmount.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light p-3 rounded text-center">
                            <div class="text-muted small">Interest Rate</div>
                            <div class="fw-bold text-primary mt-1">@(Model.Product?.InterestRate ?? 0)% p.a.</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light p-3 rounded text-center">
                            <div class="text-muted small">Annual Income</div>
                            <div class="fw-bold text-success mt-1">₹ @Model.AnnualIncome.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light p-3 rounded text-center">
                            <div class="text-muted small">Credit Score</div>
                            <div class="fw-bold text-success mt-1">@(creditEval?.CreditScore.ToString() ?? "Pending")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KYC Verification Profile -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold m-0">KYC Verification</h5></div>
            <div class="card-body pt-0">
                @if (kyc != null)
                {
                    <ul class="list-group list-group-flush" style="font-size: 0.875rem;">
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                            <span>Aadhaar Number</span>
                            <span class="fw-semibold">@kyc.AadhaarNumber</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                            <span>PAN Number</span>
                            <span class="fw-semibold">@kyc.PanNumber</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                            <span>Date of Birth</span>
                            <span class="fw-semibold">@kyc.DateOfBirth.ToString("dd MMM yyyy")</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                            <span>Gender</span>
                            <span class="fw-semibold">@kyc.Gender</span>
                        </li>
                        <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                            <span>Status</span>
                            <span class="badge-status badge-status-@KycClass(kyc.VerificationStatus)">@kyc.VerificationStatus</span>
                        </li>
                        @if (!string.IsNullOrEmpty(kyc.Remarks))
                        {
                            <li class="list-group-item px-0 py-3">
                                <div><span class="text-muted small">Verification Remarks:</span></div>
                                <div class="mt-1 p-2 bg-light rounded text-dark italic">@kyc.Remarks</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-id-card text-muted fs-3 mb-2"></i>
                        <p class="text-muted mb-0">No KYC record associated with this application.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Uploaded Documents -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold m-0">Uploaded Documents</h5></div>
            <div class="card-body pt-0">
                @if (documents.Any())
                {
                    <div class="table-responsive border-0">
                        <table class="table align-middle mb-0" style="font-size: 0.875rem;">
                            <thead>
                                <tr>
                                    <th>Document Type</th>
                                    <th>File Name</th>
                                    <th>Uploaded Date</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documents)
                                {
                                    <tr>
                                        <td><span class="fw-bold">@doc.DocumentType</span></td>
                                        <td class="text-muted small">@doc.FileName</td>
                                        <td class="text-muted small">@doc.UploadDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="badge-status badge-status-@DocClass(doc.DocumentStatus)">@doc.DocumentStatus</span></td>
                                        <td class="text-end">
                                            @if (!string.IsNullOrEmpty(doc.FilePath))
                                            {
                                                <a href="~/@doc.FilePath" class="btn btn-sm btn-outline-primary" target="_blank">
                                                    <i class="fa-solid fa-eye me-1"></i>View
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">N/A</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-folder-open text-muted fs-3 mb-2"></i>
                        <p class="text-muted mb-0">No documents uploaded.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Audit Trail -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h5 class="card-title fw-bold m-0">Application Audit Trail</h5></div>
            <div class="card-body pt-0">
                @if (auditLogs.Any())
                {
                    <div class="timeline-container py-3" style="max-height: 350px; overflow-y: auto;">
                        <ul class="list-group list-group-flush" style="font-size: 0.85rem;">
                            @foreach (var log in auditLogs)
                            {
                                <li class="list-group-item px-0 py-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="fw-bold text-dark">@log.Actions.ToString()</span>
                                        <span class="text-muted small">@(log.Timestamp?.ToString("dd MMM yyyy HH:mm") ?? "—")</span>
                                    </div>
                                    <div class="text-muted">
                                        <span>Entity: <span class="fw-semibold">@log.EntityId</span></span>
                                        @if (!string.IsNullOrEmpty(log.NewValue))
                                        {
                                            <span class="mx-2">|</span>
                                            <span>Update: <span class="fw-semibold text-primary">@log.NewValue</span></span>
                                        }
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <i class="fa-solid fa-user me-1"></i> By: <span class="fw-semibold">@(log.User?.FullName ?? "System")</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-clock-rotate-left text-muted fs-3 mb-2"></i>
                        <p class="text-muted mb-0">No audit trail records found.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar Credit Evaluation -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Credit Score & recommendation</h6></div>
            <div class="card-body pt-0" style="font-size: 0.875rem;">
                @if (creditEval != null)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span class="text-muted">Credit Score</span>
                            <span class="fw-bold text-success">@creditEval.CreditScore / 900</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            @{
                                var progressPct = ((double)creditEval.CreditScore - 300) / 600 * 100;
                                var progressBg = creditEval.CreditScore >= 750 ? "bg-success" : creditEval.CreditScore >= 650 ? "bg-warning" : "bg-danger";
                            }
                            <div class="progress-bar @progressBg" style="width: @progressPct%;"></div>
                        </div>
                    </div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                            <span class="text-muted">Debt-to-Income (DTI)</span>
                            <span class="fw-semibold">@creditEval.DebitToIncomeRatio.ToString("F1")%</span>
                        </li>
                        <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                            <span class="text-muted">Existing Liabilities</span>
                            <span class="fw-semibold">₹ @creditEval.ExistingLiabilities.ToString("N0")</span>
                        </li>
                        <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                            <span class="text-muted">Recommendation</span>
                            <span class="fw-bold text-primary">@creditEval.CreditRecommendation</span>
                        </li>
                        <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                            <span class="text-muted">Evaluation Date</span>
                            <span class="fw-semibold">@(creditEval.EvaluatedDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        </li>
                    </ul>
                    @if (!string.IsNullOrEmpty(creditEval.Comments))
                    {
                        <div class="mt-3 p-3 bg-light rounded small">
                            <span class="fw-semibold text-dark">Loan Officer Comments:</span>
                            <p class="mb-0 text-muted italic mt-1">@creditEval.Comments</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-gauge-high text-muted fs-3 mb-2"></i>
                        <p class="text-muted mb-0">No credit score evaluation has been performed.</p>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3"><h6 class="fw-bold m-0">Application Information</h6></div>
            <div class="card-body pt-0" style="font-size: 0.85rem;">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span class="text-muted">Application status</span>
                        <span class="badge-status badge-status-@StatusClass(Model.Status)">@Model.Status</span>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span class="text-muted">Employment Type</span>
                        <span class="fw-semibold">@Model.EmploymentType</span>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span class="text-muted">Product Type</span>
                        <span class="fw-semibold">@(Model.Product?.ProductName ?? "—")</span>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span class="text-muted">Created Date</span>
                        <span class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="sticky-decision-bar d-flex justify-content-between align-items-center">
    <span class="text-muted small"><i class="fa-solid fa-info-circle me-1"></i> Decision will be recorded in the audit trail.</span>
    @if (Model.Status == ApplicationStatus.UnderReview || Model.Status == ApplicationStatus.CreditEvaluated)
    {
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-warning px-4" data-bs-toggle="modal" data-bs-target="#sendBackModal">
                <i class="fa-solid fa-rotate-left me-2"></i> Send Back
            </button>
            <button type="button" class="btn btn-outline-danger px-4" data-bs-toggle="modal" data-bs-target="#rejectModal">
                <i class="fa-solid fa-xmark-circle me-2"></i> Reject Loan
            </button>
            <button type="button" class="btn btn-success px-4" data-bs-toggle="modal" data-bs-target="#approveModal">
                <i class="fa-solid fa-check-circle me-2"></i> Approve Loan
            </button>
        </div>
    }
    else
    {
        <div class="text-muted small fw-semibold">Application decision completed. Status: <span class="badge-status badge-status-@StatusClass(Model.Status)">@Model.Status</span></div>
    }
</div>

<!-- ================= APPROVE MODAL ================= -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-labelledby="approveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 py-4 px-4 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="approveModalLabel"><i class="fa-solid fa-circle-check text-success me-2"></i> Approve Loan Application</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Approval" asp-action="Approve" asp-route-id="@Model.ApplicationId" method="post">
                <div class="modal-body px-4 py-3">
                    <p class="text-muted small mb-4">Please verify or adjust the final loan terms for sanctioning.</p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Sanctioned Amount (₹)</label>
                        <input type="number" name="approvedAmount" class="form-control py-2 shadow-none" value="@Model.RequestedAmount" min="1000" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Interest Rate (% p.a.)</label>
                        <input type="number" name="approvedInterestRate" class="form-control py-2 shadow-none" value="@(Model.Product?.InterestRate ?? 8.5m)" step="0.01" min="0.1" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Tenure (Months)</label>
                        <input type="number" name="approvedTenureMonths" class="form-control py-2 shadow-none" value="@(Model.Product?.MaxTenureMonths ?? 180)" min="1" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Underwriter Comments / Notes</label>
                        <textarea name="comments" class="form-control shadow-none" rows="3" placeholder="Explain the rationale behind approval (required)..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 py-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success px-4"><i class="fa-solid fa-circle-check me-2"></i> Confirm Approval</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ================= REJECT MODAL ================= -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 py-4 px-4 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="rejectModalLabel"><i class="fa-solid fa-circle-xmark text-danger me-2"></i> Reject Loan Application</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Approval" asp-action="Reject" asp-route-id="@Model.ApplicationId" method="post">
                <div class="modal-body px-4 py-3">
                    <p class="text-muted small mb-4">Please specify the reasons for rejecting this application.</p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Rejection Reason</label>
                        <select name="rejectionReason" class="form-select py-2 shadow-none" required>
                            <option value="Low Credit Score">Low Credit Score (CIBIL below threshold)</option>
                            <option value="High DTI Ratio">High Debt-To-Income (DTI) Ratio</option>
                            <option value="Insufficient Income">Insufficient or Unstable Income</option>
                            <option value="Incomplete Documents">Incomplete or Discrepant Documents</option>
                            <option value="Policy Violation">Lending Policy Deviation</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Underwriter Rejection Remarks</label>
                        <textarea name="comments" class="form-control shadow-none" rows="3" placeholder="Provide details explaining the decline (required)..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 py-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4"><i class="fa-solid fa-circle-xmark me-2"></i> Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ================= SEND BACK MODAL ================= -->
<div class="modal fade" id="sendBackModal" tabindex="-1" aria-labelledby="sendBackModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 py-4 px-4 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="sendBackModalLabel"><i class="fa-solid fa-rotate-left text-warning me-2"></i> Send Back to Loan Officer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Approval" asp-action="SendBack" asp-route-id="@Model.ApplicationId" method="post">
                <div class="modal-body px-4 py-3">
                    <p class="text-muted small mb-4">Request corrections or additional verification. The application will be returned to the Loan Officer's desk.</p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Underwriter Instructions / Remarks</label>
                        <textarea name="remarks" class="form-control shadow-none" rows="4" placeholder="Detail the documents to update or verification required (required)..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 py-4 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning px-4"><i class="fa-solid fa-rotate-left me-2"></i> Request Corrections</button>
                </div>
            </form>
        </div>
    </div>
</div>
