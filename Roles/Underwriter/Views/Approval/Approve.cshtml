@{
    ViewData["Title"] = "Loan Approved";
    ViewData["CurrentStep"] = "Approve/Reject";
}

<div class="row mb-4">
    <div class="col-12 text-center py-4">
        <div class="bg-success text-white rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; font-size: 2.5rem;">
            <i class="fa-solid fa-check"></i>
        </div>
        <h1 class="h2 fw-bold text-dark mb-2">Loan Application Approved</h1>
        <p class="text-muted">Application <strong>LOC-9844-32</strong> has been sanctioned and is ready for disbursement processing.</p>
        <div class="d-flex gap-2 justify-content-center mt-4">
            <a href="/Disbursement/Create/9844" class="btn btn-success px-4 py-2">
                <i class="fa-solid fa-hand-holding-dollar me-2"></i> Initiate Disbursement
            </a>
            <a href="/Dashboard" class="btn btn-outline-secondary px-4 py-2">
                Back to Dashboard
            </a>
        </div>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="card border-0 shadow-sm mx-auto" style="max-width: 640px;">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold m-0">Approval Summary Receipt</h5>
    </div>
    <div class="card-body pt-0">
        <ul class="list-group list-group-flush" style="font-size: 0.875rem;">
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Application ID</span><span class="fw-bold">LOC-9844-32</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Applicant</span><span class="fw-semibold">Rajesh Kumar</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Loan Product</span><span class="fw-semibold" id="appProduct">Home Purchase Loan</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Sanctioned Amount</span><span class="fw-bold text-success" id="appAmount">₹ 45,00,000</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Interest Rate</span><span class="fw-semibold" id="appRate">8.5% p.a.</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Decision By</span><span class="fw-semibold">Anjali Sharma (Underwriter)</span>
            </li>
            <li class="list-group-item px-0 py-3 d-flex justify-content-between">
                <span class="text-muted">Decision Date</span><span class="fw-semibold">June 24, 2026</span>
            </li>
        </ul>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const loanType = localStorage.getItem("locps_loan_type") || "Home Purchase Loan";
            const loanAmount = localStorage.getItem("locps_loan_amount") ? parseInt(localStorage.getItem("locps_loan_amount")) : 4500000;
            const loanRate = localStorage.getItem("locps_loan_rate") ? parseFloat(localStorage.getItem("locps_loan_rate")) : 8.5;

            const appProduct = document.getElementById("appProduct");
            if (appProduct) appProduct.textContent = loanType;

            const appAmount = document.getElementById("appAmount");
            if (appAmount) appAmount.textContent = "₹ " + loanAmount.toLocaleString('en-IN');

            const appRate = document.getElementById("appRate");
            if (appRate) appRate.textContent = loanRate.toFixed(1) + "% p.a.";
        });
    </script>
}
