@model IEnumerable<LOCPS.Models.Disbursment>

@{
    ViewData["Title"] = "Disbursement History";
    ViewData["CurrentStep"] = "Disbursement";
}

<div class="row mb-4">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Disbursement Ledger</h1>
        <p class="text-muted mb-0">Complete record of all fund transfer transactions.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title fw-bold m-0">Transaction History</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Transaction Ref</th>
                        <th>Application ID</th>
                        <th>Applicant</th>
                        <th>Transfer Amount</th>
                        <th>Mode</th>
                        <th>Transfer Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var dbr in Model)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">@dbr.TransactionId</span></td>
                                <td><span class="fw-semibold text-primary">@(dbr.LoanApplication?.ApplicationNumber ?? $"LOC-{dbr.ApplicationId}")</span></td>
                                <td>@(dbr.LoanApplication?.Customer?.FullName ?? "Rajesh Kumar")</td>
                                <td class="fw-semibold">₹ @dbr.AmountApproved.ToString("N2")</td>
                                <td><span class="badge bg-light text-secondary border">@dbr.DisbursmentMode</span></td>
                                <td class="text-muted small">@(dbr.DisbursmentDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                <td>
                                    @if (dbr.Status == DisbursmentStatus.Completed)
                                    {
                                        <span class="badge-status badge-status-approved">Completed</span>
                                    }
                                    else if (dbr.Status == DisbursmentStatus.Failed)
                                    {
                                        <span class="badge-status badge-status-rejected">Failed</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-status-processing">Pending</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fa-solid fa-file-invoice-dollar text-muted fs-2 mb-3 d-block"></i>
                                <p class="text-muted mb-0">No disbursements recorded in history.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
