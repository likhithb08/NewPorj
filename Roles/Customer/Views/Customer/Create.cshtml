@model LOCPS.Models.LoanApplication
@{
    ViewData["Title"] = "New Loan Application";
    ViewData["CurrentStep"] = "Loan Application";
    var productDetailsJson = ViewBag.ProductDetailsJson as string ?? "[]";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Create Loan Application</h1>
        <p class="text-muted">Select a loan product and fill in the details to submit your application.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Loan Application Form</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="row g-4 mt-1">
                        <div class="col-md-12">
                            <div class="form-floating shadow-sm border rounded-3 overflow-hidden">
                                <select asp-for="ProductId" id="productSelect" class="form-select border-0" asp-items="ViewBag.Products" required>
                                    <option value="">-- Select Product --</option>
                                </select>
                                <label asp-for="ProductId">Select Loan Product <span class="text-danger">*</span></label>
                            </div>
                            <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Product info panel — shown after product is selected *@
                        <div id="productInfoPanel" class="col-md-12 d-none">
                            <div class="alert alert-info border-0 py-3 px-4 d-flex flex-wrap gap-4 align-items-center shadow-sm"
                                 style="border-radius: 12px; font-size: 0.9rem;">
                                <span><i class="fa-solid fa-percent me-2 text-primary"></i> Rate: <strong id="infoRate">—</strong></span>
                                <span><i class="fa-solid fa-arrow-down me-2 text-success"></i> Min: <strong id="infoMin">—</strong></span>
                                <span><i class="fa-solid fa-arrow-up me-2 text-danger"></i> Max: <strong id="infoMax">—</strong></span>
                                <span><i class="fa-solid fa-clock me-2 text-warning"></i> Tenure: <strong id="infoTenure">—</strong></span>
                                <span><i class="fa-solid fa-receipt me-2 text-secondary"></i> Processing Fee: <strong id="infoFee">—</strong></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating shadow-sm border rounded-3 overflow-hidden">
                                <input asp-for="RequestedAmount" id="amountInput" class="form-control border-0" placeholder="0" min="1000" max="1000000000" required />
                                <label asp-for="RequestedAmount">Requested Loan Amount (&#8377;) <span class="text-danger">*</span></label>
                            </div>
                            <div id="amountHint" class="text-muted small mt-1 d-none ms-1"></div>
                            <span asp-validation-for="RequestedAmount" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating shadow-sm border rounded-3 overflow-hidden">
                                <input asp-for="AnnualIncome" class="form-control border-0" placeholder="0" required />
                                <label asp-for="AnnualIncome">Annual Income (&#8377;) <span class="text-danger">*</span></label>
                            </div>
                            <span asp-validation-for="AnnualIncome" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <div class="form-floating shadow-sm border rounded-3 overflow-hidden">
                                <select asp-for="EmploymentType" class="form-select border-0" required>
                                    <option value="">-- Select Employment Type --</option>
                                    <option value="Salaried">Salaried</option>
                                    <option value="Self-Employed">Self-Employed</option>
                                    <option value="Business">Business Owner</option>
                                    <option value="Professional">Professional</option>
                                    <option value="Other">Other</option>
                                </select>
                                <label asp-for="EmploymentType">Employment Type <span class="text-danger">*</span></label>
                            </div>
                            <span asp-validation-for="EmploymentType" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="mt-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="declarationCheck" required />
                            <label class="form-check-label small text-muted" for="declarationCheck">
                                I hereby declare that the details provided are correct and match the verified customer profile documentation.
                            </label>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2">
                            <i class="fa-solid fa-paper-plane me-2"></i> Submit Application
                        </button>
                        <a asp-action="Index" class="btn btn-light border px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Right panel: EMI Calculator *@
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm emi-calculator-card">
            <div class="card-header border-bottom py-3">
                <h5 class="card-title fw-bold text-white m-0">
                    <i class="fa-solid fa-calculator me-2"></i> Loan EMI Estimator
                </h5>
            </div>
            <div class="card-body">
                <div class="text-center py-3">
                    <span class="small text-white-50 d-block mb-1">Estimated Monthly Installment</span>
                    <h2 class="fw-extrabold text-white m-0" id="emiAmount">&#8377; 0</h2>
                </div>
                <div class="border-top pt-3 mt-3">
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Principal Amount</span>
                        <span class="fw-semibold" id="principalAmount">&#8377; 0</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Interest Rate (p.a.)</span>
                        <span class="fw-semibold text-info" id="rateDisplay">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Tenure (Months)</span>
                        <span class="fw-semibold" id="tenureDisplay">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-white-50">Estimated Interest Payable</span>
                        <span class="fw-semibold text-warning" id="interestAmount">&#8377; 0</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-white-50">Total Amount Payable</span>
                        <span class="fw-semibold text-info" id="totalAmount">&#8377; 0</span>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <label class="small text-white-50 d-block mb-1">
                        Adjust Tenure (Months): <span id="tenureSliderVal">—</span>
                    </label>
                    <input type="range" class="form-range" id="tenureSlider"
                           min="1" max="360" value="60" disabled />
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Product data injected from the controller — no hardcoded values
    const PRODUCTS = @Html.Raw(productDetailsJson);
    const productMap = {};
    PRODUCTS.forEach(p => { productMap[p.productId] = p; });

    const productSelect = document.getElementById('productSelect');
    const amountInput   = document.getElementById('amountInput');
    const tenureSlider  = document.getElementById('tenureSlider');
    const infoPanel     = document.getElementById('productInfoPanel');
    const amountHint    = document.getElementById('amountHint');

    let currentRate   = 8.5;
    let currentTenure = 60;

    function fmt(n) {
        return '&#8377; ' + Math.round(n).toLocaleString('en-IN');
    }

    function calculateEMI() {
        const principal   = parseFloat(amountInput.value) || 0;
        const annualRate  = currentRate;
        const tenure      = currentTenure;

        document.getElementById('principalAmount').innerHTML = fmt(principal);
        document.getElementById('rateDisplay').textContent   = annualRate + '%';
        document.getElementById('tenureDisplay').textContent = tenure + ' months';
        document.getElementById('tenureSliderVal').textContent = tenure;

        if (principal > 0 && annualRate > 0 && tenure > 0) {
            const monthlyRate = annualRate / 12 / 100;
            const emi = principal * monthlyRate * Math.pow(1 + monthlyRate, tenure) /
                       (Math.pow(1 + monthlyRate, tenure) - 1);
            const totalAmt = emi * tenure;
            const interest = totalAmt - principal;

            document.getElementById('emiAmount').innerHTML    = fmt(emi);
            document.getElementById('interestAmount').innerHTML = fmt(interest);
            document.getElementById('totalAmount').innerHTML  = fmt(totalAmt);
        } else {
            document.getElementById('emiAmount').innerHTML    = '&#8377; 0';
            document.getElementById('interestAmount').innerHTML = '&#8377; 0';
            document.getElementById('totalAmount').innerHTML  = '&#8377; 0';
        }
    }

    productSelect.addEventListener('change', function () {
        const pid = parseInt(this.value);
        const p   = productMap[pid];
        if (p) {
            currentRate   = p.interestRate;
            currentTenure = p.maxTenureMonths;

            // Update info panel
            document.getElementById('infoRate').textContent   = p.interestRate + '% p.a.';
            document.getElementById('infoMin').textContent    = '₹' + p.minAmount.toLocaleString('en-IN');
            document.getElementById('infoMax').textContent    = '₹' + p.maxAmount.toLocaleString('en-IN');
            document.getElementById('infoTenure').textContent = p.maxTenureMonths + ' months';
            document.getElementById('infoFee').textContent    = '₹' + p.processingFee.toLocaleString('en-IN');
            infoPanel.classList.remove('d-none');

            // Update amount field constraints
            amountInput.min = p.minAmount;
            amountInput.max = p.maxAmount;
            amountHint.textContent = `Allowed: ₹${p.minAmount.toLocaleString('en-IN')} – ₹${p.maxAmount.toLocaleString('en-IN')}`;
            amountHint.classList.remove('d-none');

            // Update tenure slider
            tenureSlider.max   = p.maxTenureMonths;
            tenureSlider.value = p.maxTenureMonths;
            tenureSlider.disabled = false;

            calculateEMI();
        } else {
            infoPanel.classList.add('d-none');
            amountHint.classList.add('d-none');
            tenureSlider.disabled = true;
        }
    });

    amountInput.addEventListener('input', calculateEMI);
    tenureSlider.addEventListener('input', function () {
        currentTenure = parseInt(this.value);
        calculateEMI();
    });
</script>
}
