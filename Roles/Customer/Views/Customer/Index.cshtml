@model LOCPS.Common.PagedResult<LOCPS.Models.LoanApplication>
@{
    ViewData["Title"] = "Loan Applications";
    ViewData["CurrentStep"] = "Loan Application";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">My Loan Applications</h1>
        <p class="text-muted mb-0">Track your active and past loan applications.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <a asp-action="Create" class="btn btn-primary px-4 py-2"><i class="fa-solid fa-plus me-2"></i> New Application</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model != null && Model.Items.Any())
        {
            <div class="table-responsive border-0">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Application ID</th>
                            <th>Loan Product</th>
                            <th>Requested Amount</th>
                            <th>Annual Income</th>
                            <th>Status</th>
                            <th>Applied Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Items)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">@app.ApplicationNumber</span></td>
                                <td>@app.Product?.ProductName</td>
                                <td>₹ @app.RequestedAmount.ToString("N0")</td>
                                <td>₹ @app.AnnualIncome.ToString("N0")</td>
                                <td>
                                    <span class="badge-status badge-status-@GetStatusClass(app.Status)">@app.Status</span>
                                </td>
                                <td>@app.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@app.ApplicationId" class="btn btn-sm btn-light border">
                                        <i class="fa-solid fa-eye text-muted me-1"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white border-0 py-3">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            @if (Model.HasPrevious)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">Previous</a>
                                </li>
                            }
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.Page == i ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                                </li>
                            }
                            @if (Model.HasNext)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">Next</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-folder-open text-muted fs-1 mb-3"></i>
                <p class="text-muted">No loan applications found.</p>
                <a asp-action="Create" class="btn btn-primary">Create Your First Application</a>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusClass(LOCPS.Enums.ApplicationStatus status)
    {
        return status switch
        {
            LOCPS.Enums.ApplicationStatus.Submitted => "pending",
            LOCPS.Enums.ApplicationStatus.KYCPending => "pending",
            LOCPS.Enums.ApplicationStatus.KYCVerified => "processing",
            LOCPS.Enums.ApplicationStatus.UnderReview => "processing",
            LOCPS.Enums.ApplicationStatus.CreditEvaluated => "processing",
            LOCPS.Enums.ApplicationStatus.Approved => "approved",
            LOCPS.Enums.ApplicationStatus.Rejected => "rejected",
            LOCPS.Enums.ApplicationStatus.Disbursed => "approved",
            LOCPS.Enums.ApplicationStatus.Closed => "approved",
            _ => "pending"
        };
    }
}
