@{
    ViewData["Title"] = "Edit Loan Application";
    ViewData["CurrentStep"] = "Loan Application";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Edit Loan Application</h1>
        <p class="text-muted">Initiate a structured multi-step loan origination process.</p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Loan Application Wizard</h5>
            </div>
            <div class="card-body">
                <div class="accordion" id="loanWizardAccordion">
                    <div class="accordion-item border-0 mb-3 shadow-sm rounded">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#step1" aria-expanded="true">Step 1: Select Customer & Product</button>
                        </h2>
                        <div id="step1" class="accordion-collapse collapse show" data-bs-parent="#loanWizardAccordion">
                            <div class="accordion-body">
                                <form method="post" action="/Loan/Create">
                                    <div class="row g-3">
                                        <div class="col-md-12">
                                            <label class="form-label fw-semibold text-muted small">Select Customer <span class="text-danger">*</span></label>
                                            <select class="form-select py-2 shadow-none" name="customerId" required>
                                                <option value="CUST-9011" selected>Rajesh Kumar (PAN: BKDPK7849D)</option>
                                                <option value="CUST-9012">Sunitha Rao (PAN: ALKPR4821A)</option>
                                                <option value="CUST-9013">Amit Sharma (PAN: BKDPK1122C)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold text-muted small">Select Loan Product <span class="text-danger">*</span></label>
                                            <select class="form-select py-2 shadow-none" name="product" required>
                                                <option value="Home Purchase Loan" selected>Home Purchase Loan (8.5% p.a.)</option>
                                                <option value="Car Purchase Loan">Car Purchase Loan (9.2% p.a.)</option>
                                                <option value="Personal Express Loan">Personal Express Loan (10.5% p.a.)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold text-muted small">Loan Purpose <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control py-2 shadow-none" name="purpose" value="Purchase of flat" required />
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 mb-3 shadow-sm rounded">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#step2">Step 2: Loan Amount & Terms</button>
                        </h2>
                        <div id="step2" class="accordion-collapse collapse" data-bs-parent="#loanWizardAccordion">
                            <div class="accordion-body">
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-semibold text-muted small">Requested Loan Amount (INR)</label>
                                        <input type="number" class="form-control py-2 shadow-none" value="4500000" min="100000" max="10000000" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold text-muted small">Interest Rate (% p.a.)</label>
                                        <input type="number" class="form-control py-2 shadow-none" value="8.5" step="0.1" min="5" max="25" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold text-muted small">Tenure (Months)</label>
                                        <input type="number" class="form-control py-2 shadow-none" value="180" min="12" max="360" step="12" required />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 shadow-sm rounded">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#step3">Step 3: Review & Submit</button>
                        </h2>
                        <div id="step3" class="accordion-collapse collapse" data-bs-parent="#loanWizardAccordion">
                            <div class="accordion-body">
                                <div class="alert alert-info border-0 p-3" style="border-radius: var(--radius-md);">
                                    <h6 class="fw-bold mb-1"><i class="fa-solid fa-file-invoice-dollar me-1"></i> Loan Application Summary</h6>
                                    <p class="small mb-0">Please review the details before submitting to the credit validation pipeline.</p>
                                </div>
                                <div class="row g-3" style="font-size: 0.875rem;">
                                    <div class="col-md-6"><div class="bg-light p-3 rounded"><div class="text-muted small">Applicant Customer</div><div class="fw-bold text-dark mt-1">Rajesh Kumar</div></div></div>
                                    <div class="col-md-6"><div class="bg-light p-3 rounded"><div class="text-muted small">Loan Product Selected</div><div class="fw-bold text-dark mt-1">Home Purchase Loan</div></div></div>
                                    <div class="col-md-6"><div class="bg-light p-3 rounded"><div class="text-muted small">Sanction Loan Amount</div><div class="fw-bold text-primary mt-1">₹ 45,00,000</div></div></div>
                                    <div class="col-md-6"><div class="bg-light p-3 rounded"><div class="text-muted small">Applied Interest & Tenure</div><div class="fw-bold text-dark mt-1">8.5% for 180 Months</div></div></div>
                                </div>
                                <div class="mt-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="declarationCheck" required />
                                        <label class="form-check-label small text-muted" for="declarationCheck">I hereby declare that the details provided are correct and match the verified customer profile documentation.</label>
                                    </div>
                                </div>
                                <div class="mt-4 pt-3 border-top">
                                    <a href="/Document/Upload/9844" class="btn btn-primary px-4 py-2"><i class="fa-solid fa-paper-plane me-2"></i> Submit Application</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm emi-calculator-card">
            <div class="card-header border-bottom py-3">
                <h5 class="card-title fw-bold text-white m-0"><i class="fa-solid fa-calculator me-2"></i> Loan EMI Estimator</h5>
            </div>
            <div class="card-body">
                <div class="text-center py-3">
                    <span class="small text-white-50 d-block mb-1">Estimated Monthly Installment</span>
                    <h2 class="fw-extrabold text-white m-0">₹ 44,312</h2>
                </div>
                <div class="border-top pt-3 mt-3">
                    <div class="d-flex justify-content-between mb-2 small"><span class="text-white-50">Principal Amount</span><span class="fw-semibold">₹ 45,00,000</span></div>
                    <div class="d-flex justify-content-between mb-2 small"><span class="text-white-50">Estimated Interest Payable</span><span class="fw-semibold text-warning">₹ 34,76,160</span></div>
                    <div class="d-flex justify-content-between small"><span class="text-white-50">Total Amount Payable</span><span class="fw-semibold text-info">₹ 79,76,160</span></div>
                </div>
            </div>
        </div>
    </div>
</div>
