@{
    ViewData["Title"] = "Dashboard";
    ViewData["CurrentStep"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="p-4 rounded-4 text-white shadow-sm" style="background: linear-gradient(135deg, var(--secondary-navy) 0%, #1E3A5F 100%);">
            <div class="row align-items-center">
                <div class="col-md-8 mb-3 mb-md-0">
                    <h2 class="fw-bold mb-1 text-light">Welcome, Rajesh Kumar!</h2>
                    <p class="text-white-50 mb-0">Track your active loan applications, view status checklists, or browse notifications.</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/Loan/Create" class="btn btn-primary px-4 py-2 fw-semibold" style="border-radius: var(--radius-md);"><i class="fa-solid fa-plus me-2"></i> Apply for a Loan</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-spinner text-primary me-2"></i> Active Application Tracking</h6>
                <span class="badge bg-warning text-dark px-3 py-2 fw-semibold">Under Review</span>
            </div>
            <div class="card-body">
                <div class="row mb-4 text-center text-sm-start">
                    <div class="col-sm-6 col-md-3 mb-3 mb-md-0"><span class="text-muted small">Application ID</span><h6 class="fw-bold text-dark mb-0 mt-1">#LOC-9844-32</h6></div>
                    <div class="col-sm-6 col-md-3 mb-3 mb-md-0"><span class="text-muted small">Requested Amount</span><h6 class="fw-bold text-primary mb-0 mt-1">₹ 45,00,000</h6></div>
                    <div class="col-sm-6 col-md-3 mb-3 mb-md-0"><span class="text-muted small">Product Type</span><h6 class="fw-bold text-dark mb-0 mt-1">Home Purchase Loan</h6></div>
                    <div class="col-sm-6 col-md-3"><span class="text-muted small">Submission Date</span><h6 class="fw-bold text-dark mb-0 mt-1">2026-06-24</h6></div>
                </div>
                <div class="stepper-container mt-3">
                    <div class="stepper" style="min-width: auto;">
                        <div class="step-item active"><div class="step-circle"><i class="fa-solid fa-paper-plane"></i></div><div class="step-label">Submitted</div></div>
                        <div class="step-item active"><div class="step-circle"><i class="fa-solid fa-file-circle-check"></i></div><div class="step-label">Verified</div></div>
                        <div class="step-item"><div class="step-circle"><i class="fa-solid fa-gauge-high"></i></div><div class="step-label">Scored</div></div>
                        <div class="step-item"><div class="step-circle"><i class="fa-solid fa-signature"></i></div><div class="step-label">Decision</div></div>
                        <div class="step-item"><div class="step-circle"><i class="fa-solid fa-hand-holding-dollar"></i></div><div class="step-label">Disbursed</div></div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light py-3 border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="small text-muted"><i class="fa-solid fa-circle-info me-1"></i> Awaiting Document verification check by Loan Officer.</span>
                <a href="/Document/Upload/9844" class="btn btn-sm btn-outline-primary fw-semibold"><i class="fa-solid fa-upload me-1"></i> Upload Supporting Documents</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3 border-bottom"><h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-file-shield me-2 text-primary"></i> My Uploaded Documents</h6></div>
            <div class="card-body pt-0">
                <ul class="list-group list-group-flush" style="font-size: 0.875rem;">
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center"><div><i class="fa-solid fa-id-card text-muted me-2"></i> Identity Proof (PAN/Aadhaar)</div><span class="badge bg-light text-secondary border px-3 py-1">Verified by Staff</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center"><div><i class="fa-solid fa-receipt text-muted me-2"></i> Salary Slips (Last 3 Months)</div><span class="badge bg-light text-secondary border px-3 py-1">Verified by Staff</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center"><div><i class="fa-solid fa-building-columns text-muted me-2"></i> Bank Statement (6 Months)</div><span class="badge bg-warning text-dark px-3 py-1">Pending Validation</span></li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center"><div><i class="fa-solid fa-house-flag text-muted me-2"></i> Property Title Deed</div><span class="badge bg-warning text-dark px-3 py-1">Pending Validation</span></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3 border-bottom"><h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-bell me-2 text-primary"></i> Notifications</h6></div>
            <div class="card-body p-0">
                <a href="/Dashboard" class="d-block p-3 border-bottom text-decoration-none">
                    <div class="fw-semibold text-dark small">Application Submitted</div>
                    <p class="mb-0 text-muted small">Your Home Purchase Loan application has been submitted.</p>
                </a>
                <a href="/Dashboard" class="d-block p-3 text-decoration-none">
                    <div class="fw-semibold text-dark small">Documents Verified</div>
                    <p class="mb-0 text-muted small">Your uploaded PAN and Income papers are verified.</p>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 border-bottom"><h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-list me-2 text-primary"></i> Application History</h6></div>
            <div class="card-body p-0">
                <div class="table-responsive border-0">
                    <table class="table align-middle m-0">
                        <thead><tr><th>Loan Reference</th><th>Product</th><th>Sanction Amount</th><th>Rate</th><th>Status</th></tr></thead>
                        <tbody>
                            <tr><td class="fw-bold">LOC-9844-32</td><td>Home Purchase Loan</td><td>₹ 45,00,000</td><td>8.5%</td><td><span class="badge-status badge-status-processing">Under Review</span></td></tr>
                            <tr><td class="fw-bold">LOC-7788-12</td><td>Personal Express Loan</td><td>₹ 5,00,000</td><td>10.5%</td><td><span class="badge-status badge-status-approved">Approved</span></td></tr>
                            <tr><td class="fw-bold">LOC-4412-99</td><td>Car Purchase Loan</td><td>₹ 8,00,000</td><td>9.2%</td><td><span class="badge-status badge-status-pending">Pending</span></td></tr>
                            <tr><td class="fw-bold">LOC-2231-08</td><td>Personal Express Loan</td><td>₹ 2,50,000</td><td>10.5%</td><td><span class="badge-status badge-status-rejected">Rejected</span></td></tr>
                            <tr><td class="fw-bold">LOC-1155-77</td><td>Home Purchase Loan</td><td>₹ 60,00,000</td><td>8.5%</td><td><span class="badge-status badge-status-approved">Completed</span></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
