@model LOCPS.ViewModels.Reports.ReportsViewModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Reports &amp; Analytics</h1>
        <p class="text-muted mb-0">Live business intelligence dashboard &mdash; all data sourced from the database.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm px-3">
            <i class="fa-solid fa-print me-2"></i> Print Report
        </button>
    </div>
</div>

@* KPI Cards Row 1 *@
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Total Applications</div>
            <h3 class="fw-bold text-dark mb-0">@Model.TotalApplications</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Approved</div>
            <h3 class="fw-bold text-success mb-0">@Model.ApprovedCount</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Rejected</div>
            <h3 class="fw-bold text-danger mb-0">@Model.RejectedCount</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Approval Rate</div>
            <h3 class="fw-bold text-primary mb-0">@Model.ApprovalRatePercent%</h3>
        </div>
    </div>
</div>

@* KPI Cards Row 2 *@
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Pending / In-Progress</div>
            <h3 class="fw-bold text-warning mb-0">@Model.PendingCount</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Active Products</div>
            <h3 class="fw-bold text-info mb-0">@Model.ActiveProducts</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3 px-2">
            <div class="text-muted small mb-1">Total Users</div>
            <h3 class="fw-bold text-dark mb-0">@Model.TotalUsers</h3>
        </div>
    </div>
</div>

@* Product Breakdown *@
@if (Model.ProductRows.Any())
{
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold m-0">Loan Volume by Product</h6>
                </div>
                <div class="card-body">
                    @{
                        int maxApps = Model.ProductRows.Max(r => r.TotalApplications);
                        if (maxApps == 0) maxApps = 1;
                        string[] barColors = { "bg-primary", "bg-success", "bg-warning", "bg-info", "bg-danger", "bg-secondary" };
                        int ci = 0;
                    }
                    @foreach (var row in Model.ProductRows)
                    {
                        double pct = (double)row.TotalApplications / maxApps * 100;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@row.ProductName</span>
                                <span>@row.TotalApplications apps</span>
                            </div>
                            <div class="progress" style="height: 18px;">
                                <div class="progress-bar @barColors[ci % barColors.Length]"
                                     style="width: @pct.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                            </div>
                        </div>
                        ci++;
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold m-0">Product Performance Summary</h6>
                </div>
                <!-- Added px-3 padding here to prevent layout cutting -->
                <div class="card-body p-0 px-3">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center">Approved</th>
                                    <th class="text-center">Rejected</th>
                                    <!-- Added text-nowrap to prevent letter wrapping -->
                                    <th class="text-end text-nowrap">Requested (₹)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ProductRows)
                                {
                                    <tr>
                                        <td class="fw-semibold small">@row.ProductName</td>
                                        <td class="text-center">@row.TotalApplications</td>
                                        <td class="text-center"><span class="text-success fw-semibold">@row.ApprovedCount</span></td>
                                        <td class="text-center"><span class="text-danger fw-semibold">@row.RejectedCount</span></td>
                                        <td class="text-end text-muted small">@row.TotalRequestedAmount.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* Recent Applications *@
<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold m-0">Recent Applications</h6>
                <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">Live Data</span>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentApplications.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Application</th>
                                    <th>Customer</th>
                                    <th>Product</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.RecentApplications)
                                {
                                    <tr>
                                        <td><span class="fw-bold text-primary">@app.ApplicationNumber</span></td>
                                        <td>@app.CustomerName</td>
                                        <td class="text-muted small">@app.ProductName</td>
                                        <td>&#8377; @app.RequestedAmount.ToString("N0")</td>
                                        <td><span class="badge-status @app.StatusClass">@app.Status</span></td>
                                        <td class="text-muted small">@app.CreatedAt.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fa-solid fa-inbox text-muted fs-2 mb-3 d-block"></i>
                        <p class="text-muted">No loan applications in the system yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>