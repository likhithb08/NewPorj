@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Reports & Analytics</h1>
        <p class="text-muted mb-0">Business intelligence dashboard for loan origination metrics.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <div class="d-flex gap-2 justify-content-sm-end">
            <button class="btn btn-outline-secondary btn-sm px-3" onclick="window.print()">
                <i class="fa-solid fa-print me-2"></i> Print Report
            </button>
            <button class="btn btn-outline-primary btn-sm px-3" onclick="exportReportCSV()">
                <i class="fa-solid fa-download me-2"></i> Export CSV
            </button>
        </div>
    </div>
</div>

<!-- Summary KPI Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Total Volume (YTD)</div>
            <h3 class="fw-bold text-dark">₹ 14.2 Cr</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Total Applications (YTD)</div>
            <h3 class="fw-bold text-dark">156</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Avg. Processing Time</div>
            <h3 class="fw-bold text-primary">4.2 Days</h3>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Avg. Approval Rate</div>
            <h3 class="fw-bold text-success">69.4%</h3>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold m-0">Loan Volume by Product Type</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="reportProductPie" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold m-0">Monthly Disbursement Trend (₹ Lakhs)</h6>
            </div>
            <div class="card-body">
                <canvas id="reportDisbursementLine" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold m-0">Branch-wise Performance Summary</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive border-0">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Branch</th>
                                <th>Total Applications</th>
                                <th>Approved</th>
                                <th>Rejected</th>
                                <th>Approval Rate</th>
                                <th>Disbursed Volume</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">Bangalore HQ</td>
                                <td>82</td>
                                <td><span class="text-success fw-semibold">56</span></td>
                                <td><span class="text-danger fw-semibold">8</span></td>
                                <td><span class="fw-bold text-success">68.3%</span></td>
                                <td class="fw-semibold">₹ 7.8 Cr</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">Chennai Branch</td>
                                <td>44</td>
                                <td><span class="text-success fw-semibold">22</span></td>
                                <td><span class="text-danger fw-semibold">3</span></td>
                                <td><span class="fw-bold text-success">50.0%</span></td>
                                <td class="fw-semibold">₹ 3.6 Cr</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">Mumbai Branch</td>
                                <td>30</td>
                                <td><span class="text-success fw-semibold">11</span></td>
                                <td><span class="text-danger fw-semibold">1</span></td>
                                <td><span class="fw-bold text-warning">36.7%</span></td>
                                <td class="fw-semibold">₹ 2.8 Cr</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/charts.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Product Pie
            createDoughnutChart("reportProductPie",
                ["Home Loan", "Personal Loan", "Commercial", "Education", "Vehicle", "Overdraft"],
                [42, 28, 18, 8, 4, 2],
                [chartColors.primary, chartColors.success, chartColors.warning, "#8B5CF6", chartColors.info, chartColors.danger]
            );

            // Disbursement Line
            const ctx = document.getElementById("reportDisbursementLine");
            if (ctx) {
                new Chart(ctx, {
                    type: "line",
                    data: {
                        labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
                        datasets: [{
                            label: "Disbursed (₹ Lakhs)",
                            data: [180, 220, 310, 280, 350, 300],
                            borderColor: chartColors.primary,
                            backgroundColor: chartColors.primaryLight,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 5,
                            pointBackgroundColor: "#FFF",
                            pointBorderWidth: 2.5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        scales: {
                            y: { beginAtZero: true, grid: { color: "rgba(0,0,0,0.04)" } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }
        });

        function exportReportCSV() {
            const csv = [
                "Branch,Applications,Approved,Rejected,Rate,Volume",
                "Bangalore HQ,82,56,8,68.3%,₹7.8Cr",
                "Chennai Branch,44,22,3,50%,₹3.6Cr",
                "Mumbai Branch,30,11,1,36.7%,₹2.8Cr"
            ].join("\n");
            const blob = new Blob([csv], { type: "text/csv" });
            const a = document.createElement("a"); a.href = URL.createObjectURL(blob); a.download = "locps_report.csv"; a.click();
            showToast("Report Exported", "Branch performance report downloaded as CSV.", "success");
        }
    </script>
}
