@model IEnumerable<LOCPS.Models.Disbursment>
@{
    ViewData["Title"] = "Disbursement History";
    ViewData["CurrentStep"] = "Disbursement";
}

<div class="row mb-4">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Disbursement Ledger</h1>
        <p class="text-muted mb-0">Complete record of all fund transfer transactions.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <span class="badge bg-secondary rounded-pill px-3 py-2">
            Total Disbursements: <strong>@Model.Count()</strong>
        </span>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title fw-bold m-0">Transaction History</h5>
        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">Live Data</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Transaction Ref</th>
                        <th>Application</th>
                        <th>Applicant</th>
                        <th>Transfer Amount</th>
                        <th>Bank</th>
                        <th>Mode</th>
                        <th>Disbursed Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var d in Model.OrderByDescending(x => x.DisbursmentDate ?? DateTime.MinValue))
                        {
                            string statusClass = d.Status switch
                            {
                                DisbursmentStatus.Completed => "badge-status-approved",
                                DisbursmentStatus.Failed    => "badge-status-rejected",
                                _                                        => "badge-status-pending"
                            };
                            <tr>
                                <td>
                                    <span class="fw-bold text-dark small">
                                        @(string.IsNullOrEmpty(d.TransactionId) ? $"DBR-{d.DisbursmentId:D4}" : d.TransactionId)
                                    </span>
                                </td>
                                <td class="text-primary small fw-semibold">
                                    @(d.LoanApplication?.ApplicationNumber ?? $"APP-{d.ApplicationId}")
                                </td>
                                <td>@(d.LoanApplication?.Customer?.FullName ?? "—")</td>
                                <td class="fw-semibold">&#8377; @d.AmountApproved.ToString("N0")</td>
                                <td class="text-muted small">@(string.IsNullOrEmpty(d.BankName) ? "—" : d.BankName)</td>
                                <td>
                                    <span class="badge bg-light text-secondary border">@d.DisbursmentMode</span>
                                </td>
                                <td class="text-muted small">
                                    @(d.DisbursmentDate.HasValue ? d.DisbursmentDate.Value.ToString("dd MMM yyyy") : "Pending")
                                </td>
                                <td>
                                    <span class="badge-status @statusClass">@d.Status</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="fa-solid fa-money-bill-transfer text-muted fs-2 mb-3 d-block"></i>
                                <p class="text-muted mb-0">No disbursement records found.</p>
                                <p class="text-muted small">Disbursements are created by Underwriters after loan approval.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Any())
    {
        <div class="card-footer bg-white border-0 py-3 px-4">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="text-muted small">Total Disbursed</div>
                    <div class="fw-bold text-success">
                        &#8377; @Model.Where(d => d.Status == DisbursmentStatus.Completed).Sum(d => d.AmountApproved).ToString("N0")
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Completed</div>
                    <div class="fw-bold text-success">@Model.Count(d => d.Status == DisbursmentStatus.Completed)</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Pending</div>
                    <div class="fw-bold text-warning">@Model.Count(d => d.Status == DisbursmentStatus.Pending)</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small">Failed</div>
                    <div class="fw-bold text-danger">@Model.Count(d => d.Status == DisbursmentStatus.Failed)</div>
                </div>
            </div>
        </div>
    }
</div>
