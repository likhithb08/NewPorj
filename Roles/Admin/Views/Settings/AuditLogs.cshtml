@using LOCPS.Common
@model PagedResult<LOCPS.Models.Auditlog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">System Audit Trail</h1>
        <p class="text-muted">Complete record of all user actions and system events. Showing last @Model.Items.Count() of @Model.TotalCount entries.</p>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title fw-bold m-0">Activity Log</h5>
        <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold">Live Data</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive border-0">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var log in Model.Items.OrderByDescending(l => l.Timestamp))
                        {
                            <tr>
                                <td class="text-muted small">
                                    @(log.Timestamp.HasValue ? log.Timestamp.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss") : "—")
                                </td>
                                <td class="fw-semibold">@(log.User?.FullName ?? $"User#{log.UserId}")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@log.Actions</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-secondary border">@log.EntityId</span>
                                </td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(log.OldValue) ? "—" : log.OldValue)
                                </td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(log.NewValue) ? "—" : log.NewValue)
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-clipboard-list fs-2 mb-2 d-block"></i>
                                No audit log entries found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
