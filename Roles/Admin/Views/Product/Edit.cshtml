@model LOCPS.Models.LoanProduct
@{
    ViewData["Title"] = "Edit Loan Product";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Edit Loan Product</h1>
        <p class="text-muted">Update the loan product configuration.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="fw-bold m-0">Product Configuration</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="ProductId" />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="ProductName" class="form-label fw-semibold text-muted small">Product Name <span class="text-danger">*</span></label>
                            <input asp-for="ProductName" class="form-control py-2 shadow-none" required />
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="ProductDescription" class="form-label fw-semibold text-muted small">Description</label>
                            <textarea asp-for="ProductDescription" class="form-control py-2 shadow-none" rows="3"></textarea>
                            <span asp-validation-for="ProductDescription" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MinAmount" class="form-label fw-semibold text-muted small">Minimum Amount (INR) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted">₹</span>
                                <input asp-for="MinAmount" class="form-control py-2 shadow-none" required />
                            </div>
                            <span asp-validation-for="MinAmount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxAmount" class="form-label fw-semibold text-muted small">Maximum Amount (INR) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted">₹</span>
                                <input asp-for="MaxAmount" class="form-control py-2 shadow-none" required />
                            </div>
                            <span asp-validation-for="MaxAmount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="InterestRate" class="form-label fw-semibold text-muted small">Interest Rate (% p.a.) <span class="text-danger">*</span></label>
                            <input asp-for="InterestRate" step="0.1" min="0" max="100" class="form-control py-2 shadow-none" required />
                            <span asp-validation-for="InterestRate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProcessingFee" class="form-label fw-semibold text-muted small">Processing Fee (%)</label>
                            <input asp-for="ProcessingFee" step="0.01" class="form-control py-2 shadow-none" />
                            <span asp-validation-for="ProcessingFee" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxTenureMonths" class="form-label fw-semibold text-muted small">Maximum Tenure (Months) <span class="text-danger">*</span></label>
                            <input asp-for="MaxTenureMonths" min="1" max="360" class="form-control py-2 shadow-none" required />
                            <span asp-validation-for="MaxTenureMonths" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsActive" class="form-label fw-semibold text-muted small">Product Status</label>
                            <select asp-for="IsActive" class="form-select py-2 shadow-none">
                                <option value="true">Active</option>
                                <option value="false">Inactive (Draft)</option>
                            </select>
                            <span asp-validation-for="IsActive" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2"><i class="fa-solid fa-floppy-disk me-2"></i> Update Product</button>
                        <a asp-action="Index" class="btn btn-light border px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
