@model LOCPS.Models.LoanProduct
@{
    ViewData["Title"] = "Delete Loan Product";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Delete Loan Product</h1>
        <p class="text-muted">Are you sure you want to delete this loan product?</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="fw-bold m-0">Product Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4 text-muted">Product Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.ProductName</dd>
                    
                    <dt class="col-sm-4 text-muted">Description</dt>
                    <dd class="col-sm-8">@Model.ProductDescription</dd>
                    
                    <dt class="col-sm-4 text-muted">Minimum Amount</dt>
                    <dd class="col-sm-8">₹ @Model.MinAmount.ToString("N0")</dd>
                    
                    <dt class="col-sm-4 text-muted">Maximum Amount</dt>
                    <dd class="col-sm-8">₹ @Model.MaxAmount.ToString("N0")</dd>
                    
                    <dt class="col-sm-4 text-muted">Interest Rate</dt>
                    <dd class="col-sm-8">@Model.InterestRate%</dd>
                    
                    <dt class="col-sm-4 text-muted">Max Tenure</dt>
                    <dd class="col-sm-8">@Model.MaxTenureMonths Months</dd>
                    
                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Active" : "Inactive")</dd>
                </dl>
                
                <!-- Added explicit route parameter handling onto the target POST action -->
                <form asp-action="Delete" asp-route-id="@Model.ProductId" method="post">
                    <input type="hidden" name="id" value="@Model.ProductId" />
                    
                    <div class="alert alert-warning">
                        <i class="fa-solid fa-exclamation-triangle me-2"></i>
                        This action will deactivate the product. It will not be permanently deleted.
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4 py-2">
                            <i class="fa-solid fa-trash me-2"></i> Delete Product
                        </button>
                        <a asp-action="Index" class="btn btn-light border px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>