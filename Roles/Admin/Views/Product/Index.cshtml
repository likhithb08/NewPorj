@model IEnumerable<LOCPS.Models.LoanProduct>
@{
    ViewData["Title"] = "Loan Products";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Loan Product Catalog</h1>
        <p class="text-muted mb-0">Manage all available loan product offerings and configurations.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <a asp-action="Create" class="btn btn-primary px-4 py-2" style="border-radius: var(--radius-md);"><i class="fa-solid fa-plus me-2"></i> Create New Product</a>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 card-hover">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 48px; height: 48px; background-color: #1A56DB;"><i class="fa-solid fa-house"></i></div>
                            <span class="badge-status @(product.IsActive ? "badge-status-approved" : "badge-status-rejected")">@(product.IsActive ? "Active" : "Inactive")</span>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">@product.ProductName</h5>
                        @if (!string.IsNullOrEmpty(product.ProductDescription))
                        {
                            <p class="text-muted small mb-2">@product.ProductDescription</p>
                        }
                        <ul class="list-unstyled text-muted small mb-3">
                            <li class="mb-1"><i class="fa-solid fa-percent me-2 text-primary opacity-50"></i> Interest: <strong>@product.InterestRate%</strong></li>
                            <li class="mb-1"><i class="fa-solid fa-sack-dollar me-2 text-primary opacity-50"></i> Min: <strong>₹ @product.MinAmount</strong></li>
                            <li class="mb-1"><i class="fa-solid fa-sack-dollar me-2 text-primary opacity-50"></i> Max: <strong>₹ @product.MaxAmount</strong></li>
                            <li><i class="fa-solid fa-clock me-2 text-primary opacity-50"></i> Tenure: <strong>@product.MaxTenureMonths Months</strong></li>
                        </ul>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-outline-primary btn-sm flex-grow-1">View Details</a>
                            <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-light border"><i class="fa-solid fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@product.ProductId" class="btn btn-sm btn-light border text-danger"><i class="fa-solid fa-trash"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-2"></i> No loan products found. Click "Create New Product" to add one.
    </div>
}
