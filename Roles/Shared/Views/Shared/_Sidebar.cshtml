@{
    var activeRole = Context.Request.Cookies["locps_demo_role"] ?? "officer";
    var currentPath = Context.Request.Path.Value?.ToLowerInvariant() ?? "";
}

<aside id="sidebar" class="d-flex flex-column overflow-hidden" style="height:100vh">
    <div class="sidebar-header">
        <a href="/Home/Index" class="brand-logo">
            <i class="fa-solid fa-vault text-primary"></i>
            <span>LOCPS</span> Portal
        </a>
    </div>

    <div class="nav-menu flex-grow-1 overflow-auto">
        <div class="nav-section">
            <a href="/Dashboard" class="nav-link-item @(currentPath.StartsWith("/dashboard") ? "active" : "")">
                <i class="fa-solid fa-chart-pie"></i>
                Dashboard
            </a>
            @* <a href="/Notification" class="nav-link-item @(currentPath.StartsWith("/notification") ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                Notifications
            </a> *@
        </div>

        @if (activeRole == "customer")
        {
            <div class="nav-section">
                <div class="nav-heading">My Services</div>
                <a href="/Customer/Create" class="nav-link-item @(currentPath.StartsWith("/customer/create") ? "active" : "")">
                    <i class="fa-solid fa-file-signature"></i>
                    Apply for Loan
                </a>
            </div>
        }

        @if (activeRole == "officer")
        {
            <div class="nav-section">
                <div class="nav-heading">Customers & Loans</div>
                <a href="/Customer" class="nav-link-item @(currentPath.StartsWith("/customer") ? "active" : "")">
                    <i class="fa-solid fa-users"></i>
                    Customer Directory
                </a>
                <a href="/Loan" class="nav-link-item @(currentPath.StartsWith("/loan") ? "active" : "")">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    Loan Applications
                </a>

                <div class="nav-heading">Origination Steps</div>
                <a href="/Kyc/Verify/9844" class="nav-link-item @(currentPath.StartsWith("/kyc") ? "active" : "")">
                    <i class="fa-solid fa-id-card"></i>
                    KYC Verification
                </a>
                <a href="/Credit/Evaluate/9844" class="nav-link-item @(currentPath.StartsWith("/credit") ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i>
                    Credit Evaluation
                </a>
                <a href="/Document/Validate/9844" class="nav-link-item @(currentPath.Contains("/document/validate") ? "active" : "")">
                    <i class="fa-solid fa-file-shield"></i>
                    Document Validation
                </a>
            </div>
        }

        @if (activeRole == "underwriter")
        {
            <div class="nav-section">
                <div class="nav-heading">Credit Decisioning</div>
                <a href="/Approval/Review/9844" class="nav-link-item @(currentPath.StartsWith("/approval") ? "active" : "")">
                    <i class="fa-solid fa-signature"></i>
                    Underwriter Review
                </a>
                <a href="/Disbursement/Create/9844" class="nav-link-item @(currentPath.Contains("/disbursement/create") ? "active" : "")">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                    Initiate Disbursement
                </a>
                <a href="/Disbursement/History" class="nav-link-item @(currentPath.Contains("/disbursement/history") ? "active" : "")">
                    <i class="fa-solid fa-money-bill-transfer"></i>
                    Disbursement History
                </a>
            </div>
        }

        @if (activeRole == "admin")
        {
            <div class="nav-section">
                <div class="nav-heading">Administration</div>
                <a href="/Product" class="nav-link-item @(currentPath.StartsWith("/product") ? "active" : "")">
                    <i class="fa-solid fa-box-archive"></i>
                    Loan Products
                </a>
                <a href="/UserManagement" class="nav-link-item @(currentPath.StartsWith("/usermanagement") ? "active" : "")">
                    <i class="fa-solid fa-user-shield"></i>
                    User Management
                </a>
                <a href="/Settings/ScoringRules" class="nav-link-item @(currentPath.Contains("/settings/scoringrules") ? "active" : "")">
                    <i class="fa-solid fa-sliders"></i>
                    Scoring Engine Weights
                </a>
                <a href="/Settings/AuditLogs" class="nav-link-item @(currentPath.Contains("/settings/auditlogs") ? "active" : "")">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    Audit Log Trail
                </a>

                <div class="nav-heading">Settlement & Reports</div>
                <a href="/Disbursement/History" class="nav-link-item @(currentPath.Contains("/disbursement/history") ? "active" : "")">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                    Disbursements
                </a>
                <a href="/Reports" class="nav-link-item @(currentPath.StartsWith("/reports") ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i>
                    Reports & Analytics
                </a>
            </div>
        }
    </div>

    <div class="sidebar-footer">
        <div class="mt-3 text-center">
            <a href="/Account/Logout" class="text-white-50 small text-decoration-none">
                <i class="fa-solid fa-right-from-bracket me-1"></i> Sign Out
            </a>
        </div>
    </div>
</aside>
