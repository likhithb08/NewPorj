<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LOCPS Banking Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body>
    <input type="checkbox" id="sidebarToggle" class="sidebar-toggle-input" aria-hidden="true" tabindex="-1">

    @await Html.PartialAsync("_Sidebar")

    <div id="wrapper">
        @await Html.PartialAsync("_Topbar")

        <main id="content">
            @await Html.PartialAsync("_Breadcrumb")
            @RenderBody()
        </main>

        @await Html.PartialAsync("_Footer")
    </div>

    @await Html.PartialAsync("_Toast")
    @await Html.PartialAsync("_ConfirmationModal")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
