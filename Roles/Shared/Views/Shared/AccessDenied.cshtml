@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LOCPS — Access Denied</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .error-card {
            max-width: 480px;
            width: 100%;
            padding: 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05), 0 4px 6px -2px rgba(0,0,0,0.02);
            border: 1px solid #E2E8F0;
            text-align: center;
        }
        .icon-box {
            width: 64px;
            height: 64px;
            background-color: #FEE2E2;
            color: #EF4444;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px auto;
            font-size: 24px;
        }
        .btn-home {
            background-color: #1A56DB;
            color: white;
            font-weight: 600;
            font-size: 14px;
            padding: 10px 24px;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-block;
        }
        .btn-home:hover {
            background-color: #1A4BBD;
            color: white;
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="icon-box">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3 class="fw-bold text-dark mb-2">Access Denied</h3>
        <p class="text-muted small mb-4">You do not have authorization to view this module. If you believe this is in error, please contact your system administrator or switch to an authorized role.</p>
        <a href="/Dashboard" class="btn-home">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</body>
</html>
