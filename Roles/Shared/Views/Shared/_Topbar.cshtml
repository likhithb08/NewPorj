@using System.Security.Claims
@inject LOCPS.Data.AppDbContext _context

@{
    var activeRole = Context.Request.Cookies["locps_demo_role"] ?? "officer";
    
    // 1. Map the role label instantly based on the cookie so it NEVER mismatches
    var roleLabel = "Loan Officer";
    var initials = "LO";
    var fullName = "Loan Officer";

    if (activeRole == "customer") { roleLabel = "Portal Customer"; initials = "CR"; fullName = "Customer User"; }
    else if (activeRole == "underwriter") { roleLabel = "Senior Underwriter"; initials = "UW"; fullName = "Underwriter User"; }
    else if (activeRole == "admin") { roleLabel = "Super Admin"; initials = "SA"; fullName = "System Administrator"; }

    // 2. Safely attempt to overwrite the generic placeholder name with the real DB name
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    // Parse the string userId to an int to prevent compiler error CS0019
    if (!string.IsNullOrEmpty(userId) && int.TryParse(userId, out int parsedUserId))
    {
        var dbUser = _context.Users.FirstOrDefault(u => u.UserId == parsedUserId);
        
        if (dbUser != null && !string.IsNullOrWhiteSpace(dbUser.FullName))
        {
            fullName = dbUser.FullName;

            // 3. Dynamically recalculate initials from their actual database name
            var names = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = names.Length > 1
                ? $"{names[0][0]}{names[1][0]}".ToUpper()
                : $"{names[0][0]}".ToUpper();
        }
    }
}

<header id="topbar">
    <div class="d-flex align-items-center gap-3">
        <label for="sidebarToggle" class="toggle-sidebar-btn d-lg-none mb-0" aria-label="Toggle Sidebar">
            <i class="fa-solid fa-bars"></i>
        </label>
        <div class="search-bar d-none d-md-flex align-items-center bg-light px-3 py-1 rounded-pill">
            <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
            <input type="text" class="form-control border-0 bg-transparent py-1 shadow-none" placeholder="Search application number, customer, etc..." style="width: 280px; font-size: 0.85rem;" />
        </div>
    </div>
    
    <div class="d-flex align-items-center gap-3">
        <!-- Notifications Dropdown -->
        <div class="dropdown">
            <button class="btn btn-link position-relative text-muted p-2 border-0 shadow-none" type="button" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fa-regular fa-bell fs-5"></i>
                <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.6rem;">2</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-0" aria-labelledby="notifDropdown" style="width: 320px; font-size: 0.85rem;">
                <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-light">
                    <span class="fw-bold">Notifications</span>
                    <a href="/Notification" class="text-primary text-decoration-none small">View All</a>
                </div>
                <div class="list-group list-group-flush" style="max-height: 240px; overflow-y: auto;">
                    @if (activeRole == "customer")
                    {
                        <a href="/Dashboard" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">Application Submitted</span>
                                <span class="text-muted small text-nowrap">10m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Your Home Purchase Loan application has been submitted.</p>
                        </a>
                        <a href="/Dashboard" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">Documents Verified</span>
                                <span class="text-muted small text-nowrap">5m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Your uploaded PAN and Income papers are verified.</p>
                        </a>
                    }
                    else if (activeRole == "underwriter")
                    {
                        <a href="/Approval/Review/9844" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">Ready for Underwriting</span>
                                <span class="text-muted small text-nowrap">15m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Application #LOC-9844-32 has passed Credit Score thresholds.</p>
                        </a>
                        <a href="/Disbursement/Create/9844" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">Disbursement Pending</span>
                                <span class="text-muted small text-nowrap">1h ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Approved application #LOC-7788-12 needs payment processing.</p>
                        </a>
                    }
                    else if (activeRole == "admin")
                    {
                        <a href="/UserManagement" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">New User Registered</span>
                                <span class="text-muted small text-nowrap">30m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">New loan officer account registered.</p>
                        </a>
                        <a href="/Settings/ScoringRules" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">System Weights Updated</span>
                                <span class="text-muted small text-nowrap">2h ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Scoring engine weights were successfully modified.</p>
                        </a>
                    }
                    else
                    {
                        <a href="/Kyc/Verify/9844" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">KYC Uploaded</span>
                                <span class="text-muted small text-nowrap">2m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Customer 'Rajesh Kumar' uploaded verification docs.</p>
                        </a>
                        <a href="/Document/Validate/9844" class="list-group-item list-group-item-action p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">Documents Uploaded</span>
                                <span class="text-muted small text-nowrap">15m ago</span>
                            </div>
                            <p class="mb-0 text-muted small">Application #LOC-9844-32 has documents ready for validation.</p>
                        </a>
                    }
                </div>
                <div class="p-2 border-top text-center bg-light">
                    <a href="/Notification" class="btn btn-sm btn-link text-muted text-decoration-none w-100">View All Notifications</a>
                </div>
            </div>
        </div>

        <div class="border-start h-100 py-3 mx-1"></div>

        <!-- Dynamic Profile Dropdown -->
        <div class="dropdown">
            <button class="btn btn-link d-flex align-items-center gap-2 text-decoration-none text-dark p-1 border-0 shadow-none" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; font-weight: 700;">@initials</div>
                <div class="text-start d-none d-sm-block">
                    <div class="fw-semibold lh-1" style="font-size: 0.85rem;">@fullName</div>
                    <span class="text-muted small" style="font-size: 0.75rem;">@roleLabel</span>
                </div>
                <i class="fa-solid fa-chevron-down text-muted small"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" aria-labelledby="profileDropdown">
                <li><a class="dropdown-item py-2" href="/Settings"><i class="fa-solid fa-user-gear me-2 text-muted"></i> Account Settings</a></li>
                @if (activeRole == "admin")
                {
                    <li><a class="dropdown-item py-2" href="/Settings/AuditLogs"><i class="fa-solid fa-clock-rotate-left me-2 text-muted"></i> Audit Trails</a></li>
                }
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 text-danger" href="/Account/Login"><i class="fa-solid fa-right-from-bracket me-2"></i> Logout</a></li>
            </ul>
        </div>
    </div>
</header>