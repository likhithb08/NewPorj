@{
    ViewData["Title"] = "Loan Application Details";
    ViewData["CurrentStep"] = "Loan Application";
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Application Details: LOC-9844-32</h1>
        <p class="text-muted mb-0">Track and advance the origination steps for this customer.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        <div class="d-flex gap-2 justify-content-sm-end">
            <a href="/Loan/Edit/9844" class="btn btn-outline-primary" style="border-radius: var(--radius-md);"><i class="fa-solid fa-pen-to-square me-2"></i> Edit Terms</a>
            <a href="/Kyc/Verify/9844" class="btn btn-success" style="border-radius: var(--radius-md);"><i class="fa-solid fa-id-card me-2"></i> Verify KYC</a>
            <a href="/Approval/Review/9844" class="btn btn-primary" style="border-radius: var(--radius-md);"><i class="fa-solid fa-signature me-2"></i> Underwrite Decision</a>
        </div>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row g-4">
    <!-- Financial Overview -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Application Summary: <span id="detProductType">Home Purchase Loan</span></h5>
            </div>
            <div class="card-body pt-0">
                <div class="row g-3">
                    <div class="col-md-6 col-lg-3">
                        <div class="bg-light p-3 rounded text-center">
                            <span class="text-muted small">Sanction Amount</span>
                            <h4 class="fw-bold text-dark mt-1" id="detAmount">₹ 45L</h4>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="bg-light p-3 rounded text-center">
                            <span class="text-muted small">Annual Rate</span>
                            <h4 class="fw-bold text-primary mt-1" id="detRate">8.5%</h4>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="bg-light p-3 rounded text-center">
                            <span class="text-muted small">Tenure Months</span>
                            <h4 class="fw-bold text-dark mt-1" id="detTenure">180m</h4>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="bg-light p-3 rounded text-center">
                            <span class="text-muted small">Estimated EMI</span>
                            <h4 class="fw-bold text-success mt-1" id="detEmi">₹ 44.3K</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progress Tracking Cards -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold text-dark m-0">Origination Workflow Status Checklist</h5>
            </div>
            <div class="card-body pt-0">
                <div class="list-group list-group-flush" style="font-size: 0.875rem;">
                    <!-- Step 1 -->
                    <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;"><i class="fa-solid fa-check small"></i></div>
                            <div>
                                <div class="fw-semibold">Customer Onboarded</div>
                                <span class="text-muted small">Customer details successfully registered in core.</span>
                            </div>
                        </div>
                        <a href="/Customer/Details/9011" class="btn btn-sm btn-light border">Details</a>
                    </div>
                    <!-- Step 2 -->
                    <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;"><i class="fa-solid fa-check small"></i></div>
                            <div>
                                <div class="fw-semibold">KYC Verification Check</div>
                                <span class="text-muted small">PAN/Aadhaar validated matching.</span>
                            </div>
                        </div>
                        <a href="/Kyc/Verify/9844" class="btn btn-sm btn-light border">Verify</a>
                    </div>
                    <!-- Step 3 -->
                    <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;"><i class="fa-solid fa-clock-rotate-left small"></i></div>
                            <div>
                                <div class="fw-semibold">Credit Score Checks</div>
                                <span class="text-muted small">Credit score computed, awaiting rule validation.</span>
                            </div>
                        </div>
                        <a href="/Credit/Evaluate/9844" class="btn btn-sm btn-light border">Evaluate</a>
                    </div>
                    <!-- Step 4 -->
                    <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;"><i class="fa-solid fa-minus small"></i></div>
                            <div>
                                <div class="fw-semibold">Document Validation</div>
                                <span class="text-muted small">Salary receipts & collateral documents verification.</span>
                            </div>
                        </div>
                        <a href="/Document/Upload/9844" class="btn btn-sm btn-light border">Documents</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Applicant Summary Card -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold text-dark m-0">Applicant Information</h6>
            </div>
            <div class="card-body pt-0">
                <ul class="list-group list-group-flush" style="font-size: 0.85rem;">
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Applicant Name</div>
                        <div class="fw-bold mt-1">Rajesh Kumar</div>
                    </li>
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Loan Product</div>
                        <div class="fw-bold mt-1" id="detProductTypeRight">Home Purchase Loan</div>
                    </li>
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Employment Type & Monthly Income</div>
                        <div class="fw-bold mt-1">Salaried | ₹ 85,000 / mo</div>
                    </li>
                    <li class="list-group-item px-0 py-3">
                        <div class="text-muted">Loan Purpose Detail</div>
                        <div class="fw-bold mt-1">Purchase of flat in Bangalore</div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const loanType = localStorage.getItem("locps_loan_type") || "Home Purchase Loan";
            const loanAmount = localStorage.getItem("locps_loan_amount") ? parseInt(localStorage.getItem("locps_loan_amount")) : 4500000;
            const loanRate = localStorage.getItem("locps_loan_rate") ? parseFloat(localStorage.getItem("locps_loan_rate")) : 8.5;
            const loanTenure = localStorage.getItem("locps_loan_tenure") ? parseInt(localStorage.getItem("locps_loan_tenure")) : 180;
            
            // EMI Calculation
            const monthlyRate = loanRate / 12 / 100;
            const emi = Math.round((loanAmount * monthlyRate * Math.pow(1 + monthlyRate, loanTenure)) / (Math.pow(1 + monthlyRate, loanTenure) - 1));

            const detProductType = document.getElementById("detProductType");
            if (detProductType) detProductType.textContent = loanType;

            const detProductTypeRight = document.getElementById("detProductTypeRight");
            if (detProductTypeRight) detProductTypeRight.textContent = loanType;

            const detAmount = document.getElementById("detAmount");
            if (detAmount) detAmount.textContent = "₹ " + (loanAmount / 100000).toFixed(1) + "L";

            const detRate = document.getElementById("detRate");
            if (detRate) detRate.textContent = loanRate.toFixed(1) + "%";

            const detTenure = document.getElementById("detTenure");
            if (detTenure) detTenure.textContent = loanTenure + "m";

            const detEmi = document.getElementById("detEmi");
            if (detEmi) detEmi.textContent = "₹ " + (emi / 1000).toFixed(1) + "K";
        });
    </script>
}
