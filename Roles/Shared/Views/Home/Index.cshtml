@{
    ViewData["Title"] = "LOCPS — Premium Digital Lending Platform";
    Layout = null; // Standalone landing page design
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LOCPS — Loan Origination & Credit Processing System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/theme.css" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
            color: #1E293B;
            overflow-x: hidden;
        }

        .landing-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .hero-section {
            background: radial-gradient(circle at 80% 20%, rgba(13, 110, 253, 0.1) 0%, rgba(248, 250, 252, 0) 50%),
                        linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
            color: #FFFFFF;
            padding: 100px 0 120px 0;
            position: relative;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 40px;
            background: #F8FAFC;
            clip-path: polygon(0 100%, 100% 100%, 100% 0);
        }

        .product-card {
            border: 1px solid #E2E8F0;
            border-radius: var(--radius-lg);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: #FFFFFF;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: rgba(13, 110, 253, 0.3);
        }

        .icon-box {
            width: 60px;
            height: 60px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 20px;
        }

        .feature-icon {
            width: 48px;
            height: 48px;
            background: rgba(13, 110, 253, 0.08);
            color: var(--primary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .step-badge {
            width: 32px;
            height: 32px;
            background: var(--primary-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>

    <!-- Header Navigation -->
    <header class="landing-header">
        <div class="container py-3">
            <div class="d-flex justify-content-between align-items-center">
                <a href="/" class="d-flex align-items-center text-decoration-none fw-bold text-dark fs-4">
                    <i class="fa-solid fa-vault me-2" style="color: var(--primary-blue);"></i>
                    <span style="letter-spacing: -0.5px;">LOCPS</span>
                </a>
                <nav class="d-none d-md-flex gap-4 align-items-center">
                    <a href="#catalogue" class="text-secondary text-decoration-none fw-medium small">Loan Products</a>
                    <a href="#features" class="text-secondary text-decoration-none fw-medium small">Key Features</a>
                    <a href="#process" class="text-secondary text-decoration-none fw-medium small">How it Works</a>
                </nav>
                <div class="d-flex gap-2">
                    <a href="/Account/Login" class="btn btn-outline-primary px-4 fw-semibold small" style="border-radius: var(--radius-md);">
                        <i class="fa-solid fa-right-to-bracket me-2"></i>Access Portal
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Banner -->
    <section class="hero-section border-0">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7 py-5">
                    <span class="badge bg-primary bg-opacity-20 text-primary-light border border-primary border-opacity-30 rounded-pill px-3 py-2 mb-3 fw-semibold small">
                        <i class="fa-solid fa-sparkles me-2"></i>Institutional Lending System
                    </span>
                    <h1 class="display-4 fw-extrabold text-white mb-3" style="letter-spacing: -1px; line-height: 1.15;">
                        Next-Gen Digital <span class="text-primary">Loan Origination</span> & Credit Processing
                    </h1>
                    <p class="fs-5 text-white-50 mb-5 fw-normal" style="max-width: 600px;">
                        Seamless credit evaluations, automated KYC checks, and structured origination workflows tailored for modern retail and commercial banking.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="#catalogue" class="btn btn-primary btn-lg px-4 py-3 fw-semibold" style="border-radius: var(--radius-md);">
                            Browse Catalog <i class="fa-solid fa-arrow-down ms-2"></i>
                        </a>
                        <a href="/Account/Login" class="btn btn-outline-light btn-lg px-4 py-3 fw-semibold" style="border-radius: var(--radius-md);">
                            Portal Login <i class="fa-solid fa-angle-right ms-2"></i>
                        </a>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block text-center position-relative">
                    <div class="p-4 rounded-4" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(10px);">
                        <h5 class="text-white fw-bold mb-4 text-start"><i class="fa-solid fa-calculator me-2 text-primary"></i> Instant EMI Calculator</h5>
                        <div class="mb-3 text-start">
                            <label class="text-white-50 small mb-1">Loan Amount</label>
                            <h4 class="text-white fw-bold">₹ 50,00,000</h4>
                        </div>
                        <div class="mb-3 text-start">
                            <label class="text-white-50 small mb-1">Tenure (Years)</label>
                            <h4 class="text-white fw-bold">20 Years</h4>
                        </div>
                        <div class="mb-4 text-start">
                            <label class="text-white-50 small mb-1">Interest Rate</label>
                            <h4 class="text-white fw-bold">8.5% p.a.</h4>
                        </div>
                        <div class="border-top border-secondary border-opacity-30 pt-3 text-start">
                            <span class="text-white-50 small d-block">Estimated Monthly EMI</span>
                            <h3 class="text-primary fw-extrabold mb-0">₹ 43,391 <span class="fs-6 text-white-50 font-normal">/ month</span></h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Product Catalogue Section -->
    <section class="py-5 border-0" id="catalogue" style="margin-top: -30px;">
        <div class="container position-relative" style="z-index: 10;">
            <div class="text-center mb-5">
                <h2 class="fw-bold text-dark mb-2">Explore Loan Catalog</h2>
                <p class="text-muted">Select a product below to apply directly through our secure customer portal.</p>
            </div>

            <div class="row g-4 justify-content-center">
                <!-- Home Loan -->
                <div class="col-md-6 col-lg-4">
                    <div class="product-card p-4">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary">
                            <i class="fa-solid fa-house-chimney"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Home Purchase Loan</h4>
                        <p class="text-muted small flex-grow-1">
                            Finance your dream home with our competitive housing loan options. Features low processing fees and long repayment tenures.
                        </p>
                        <div class="bg-light p-3 rounded mb-4" style="border-radius: var(--radius-md);">
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Interest Rate</span>
                                <span class="fw-semibold text-dark">From 8.5% p.a.</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Tenure Range</span>
                                <span class="fw-semibold text-dark">Up to 30 Years</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Processing Fee</span>
                                <span class="fw-semibold text-dark">0.25% of amount</span>
                            </div>
                        </div>
                        <a href="/Account/Login?returnUrl=/Loan/Create&type=home" class="btn btn-primary w-100 fw-semibold" style="border-radius: var(--radius-md);">
                            Apply for Home Loan
                        </a>
                    </div>
                </div>

                <!-- Car Loan -->
                <div class="col-md-6 col-lg-4">
                    <div class="product-card p-4">
                        <div class="icon-box bg-success bg-opacity-10 text-success">
                            <i class="fa-solid fa-car-side"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Car Purchase Loan</h4>
                        <p class="text-muted small flex-grow-1">
                            Get behind the wheel of your next vehicle with zero down-payment schemes and flexible repayment models.
                        </p>
                        <div class="bg-light p-3 rounded mb-4" style="border-radius: var(--radius-md);">
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Interest Rate</span>
                                <span class="fw-semibold text-dark">From 9.2% p.a.</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Tenure Range</span>
                                <span class="fw-semibold text-dark">Up to 7 Years</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Max Funding</span>
                                <span class="fw-semibold text-dark">90% of on-road cost</span>
                            </div>
                        </div>
                        <a href="/Account/Login?returnUrl=/Loan/Create&type=car" class="btn btn-success w-100 text-white fw-semibold" style="border-radius: var(--radius-md);">
                            Apply for Car Loan
                        </a>
                    </div>
                </div>

                <!-- Personal Loan -->
                <div class="col-md-6 col-lg-4">
                    <div class="product-card p-4">
                        <div class="icon-box bg-info bg-opacity-10 text-info">
                            <i class="fa-solid fa-circle-dollar-to-slot"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Personal Express Loan</h4>
                        <p class="text-muted small flex-grow-1">
                            Meet unplanned medical, emergency, travel, or wedding expenses with quick-approval, collateral-free loans.
                        </p>
                        <div class="bg-light p-3 rounded mb-4" style="border-radius: var(--radius-md);">
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Interest Rate</span>
                                <span class="fw-semibold text-dark">From 10.5% p.a.</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Tenure Range</span>
                                <span class="fw-semibold text-dark">Up to 5 Years</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Collateral</span>
                                <span class="fw-semibold text-dark">Not Required</span>
                            </div>
                        </div>
                        <a href="/Account/Login?returnUrl=/Loan/Create&type=personal" class="btn btn-info w-100 text-white fw-semibold" style="border-radius: var(--radius-md);">
                            Apply for Personal Loan
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5 bg-white" id="features">
        <div class="container">
            <div class="row align-items-center py-4">
                <div class="col-lg-5 mb-5 mb-lg-0">
                    <h2 class="fw-bold text-dark mb-3">Why Banks and Customers Trust LOCPS</h2>
                    <p class="text-muted">Our centralized origination framework ensures secure transitions, faster document checklists, and precise risk weight calculations.</p>
                </div>
                <div class="col-lg-7">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <div class="feature-icon mb-3"><i class="fa-solid fa-shield-halved"></i></div>
                            <h5 class="fw-bold text-dark">Role-Based Gateways</h5>
                            <p class="text-muted small">Divided views protecting operations for Admins, Officers, Underwriters, and Portal Customers.</p>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-icon mb-3"><i class="fa-solid fa-chart-line"></i></div>
                            <h5 class="fw-bold text-dark">Scoring Engine</h5>
                            <p class="text-muted small">Automated credit scoring and dynamic weight configurations supporting risk analysis teams.</p>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-icon mb-3"><i class="fa-solid fa-file-shield"></i></div>
                            <h5 class="fw-bold text-dark">Document Uploads</h5>
                            <p class="text-muted small">Interactive drag-and-drop checklists showing document verification status logs inline.</p>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-icon mb-3"><i class="fa-solid fa-bolt"></i></div>
                            <h5 class="fw-bold text-dark">Disbursal Gateway</h5>
                            <p class="text-muted small">Tabbed disbursement execution screens facilitating quick bank ledger updates.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-4 bg-dark text-white-50 border-top border-secondary border-opacity-10">
        <div class="container">
            <div class="row">
                <div class="col-md-6 mb-3 mb-md-0 text-center text-md-start">
                    <span class="fw-bold text-white fs-5"><i class="fa-solid fa-vault text-primary me-2"></i>LOCPS</span>
                    <p class="small mb-0 mt-2">Project by Likhith B, Richa, Bhargav, Mani, Rajeshwari, Bindu  </p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="/Account/Login" class="text-white-50 text-decoration-none small">Portal Admin Login</a>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
