@{
    Layout = null;
}
@model LOCPS.ViewModels.Users.UserCreateViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LOCPS — Customer Registration</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/theme.css" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--secondary-navy) 0%, #1E3A5F 50%, var(--primary-blue) 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px;
        }
        .register-card { width: 100%; max-width: 680px; border-radius: var(--radius-xl); box-shadow: 0 25px 50px rgba(0,0,0,0.3); border: none; overflow: hidden; }
        .register-header { background: #FFFFFF; border-bottom: 1px solid rgba(226, 232, 240, 0.8); padding: 30px; }
    </style>
</head>
<body>
    <div class="card register-card bg-white">
        <div class="register-header text-center bg-white">
            <h2 class="fw-bold m-0" style="color: var(--secondary-navy);">
                <i class="fa-solid fa-user-plus me-2" style="color: var(--primary-blue);"></i>Customer Registration
            </h2>
            <p class="text-muted small mb-0 mt-1">Create your customer account to view loan products, submit applications, and track your loan status.</p>
        </div>

        <div class="card-body p-4 pt-3">
            <form asp-action="Register" asp-controller="Account" method="post">
                <!-- Customers register with RoleId = 0 (Customer role) -->
                <input type="hidden" name="RoleId" value="1" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">User Name <span class="text-danger">*</span></label>
                        <input type="text" name="UserName" class="form-control py-2 shadow-none" placeholder="e.g. rajesh_kumar" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Full Name <span class="text-danger">*</span></label>
                        <input type="text" name="FullName" class="form-control py-2 shadow-none" placeholder="e.g. Rajesh Kumar" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Email Address <span class="text-danger">*</span></label>
                        <input type="email" name="Email" class="form-control py-2 shadow-none" placeholder="e.g. customer@domain.com" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Phone Number <span class="text-danger">*</span></label>
                        <input type="tel" name="PhoneNumber" class="form-control py-2 shadow-none" placeholder="e.g. +91 98765 43210" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Password <span class="text-danger">*</span></label>
                        <input type="password" name="Password" class="form-control py-2 shadow-none" placeholder="Create password" required minlength="6" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted small">Confirm Password <span class="text-danger">*</span></label>
                        <input type="password" id="confirmPassword" class="form-control py-2 shadow-none" placeholder="Confirm password" required minlength="6" />
                    </div>
                </div>
                <div class="mt-4 pt-2 d-flex flex-column gap-2">
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" style="border-radius: var(--radius-md);">
                        <i class="fa-solid fa-user-plus me-2"></i> Register Account
                    </button>
                    <a href="/Account/Login" class="btn btn-light border w-100 py-2" style="border-radius: var(--radius-md);">
                        Back to Login
                    </a>
                </div>
            </form>
        </div>

        <div class="bg-light text-center py-3 border-top">
            <span class="text-muted small">&copy; 2026 LOCPS Banking Portal. Secured with TLS 1.3.</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            const password = document.querySelector('input[name="Password"]').value;
            const confirmPassword = document.querySelector('#confirmPassword').value;

            if (password !== confirmPassword) {
                e.preventDefault();
                alert('Passwords do not match. Please try again.');
                document.querySelector('#confirmPassword').focus();
            }
        });
    </script>
</body>
</html>
