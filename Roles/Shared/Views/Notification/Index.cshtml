@model IEnumerable<LOCPS.Models.Notification>
@using LOCPS.Enums

@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="row mb-4 align-items-center">
    <div class="col-sm-6">
        <h1 class="h3 fw-bold text-dark m-0">Notification Inbox</h1>
        <p class="text-muted mb-0">System alerts, workflow updates and compliance notices.</p>
    </div>
    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
        @if (unreadCount > 0)
        {
            <form asp-controller="Notification" asp-action="MarkAllRead" method="post" style="display:inline;">
                <button type="submit" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-check-double me-2"></i> Mark All Read
                </button>
            </form>
        }
        else
        {
            <button class="btn btn-outline-secondary btn-sm" disabled>
                <i class="fa-solid fa-check-double me-2"></i> All Read
            </button>
        }
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            @if (Model.Any())
            {
                @foreach (var notif in Model)
                {
                    var bgClass = notif.IsRead ? "" : "bg-light bg-opacity-50 border-start border-4 border-primary";
                    var badgeColor = notif.NotificationType switch
                    {
                        NotificationType.ApprovalUpdate => "bg-success",
                        NotificationType.DisbursementProcessed => "bg-success",
                        NotificationType.DocumentRequest => "bg-warning",
                        NotificationType.ApplicationStatusUpdate => "bg-info",
                        NotificationType.KYCVerified => "bg-primary",
                        NotificationType.CreditEvaluated => "bg-purple",
                        _ => "bg-secondary"
                    };
                    var iconClass = notif.NotificationType switch
                    {
                        NotificationType.ApprovalUpdate => "fa-solid fa-signature",
                        NotificationType.DisbursementProcessed => "fa-solid fa-hand-holding-dollar",
                        NotificationType.DocumentRequest => "fa-solid fa-file-circle-exclamation",
                        NotificationType.ApplicationStatusUpdate => "fa-solid fa-bell",
                        NotificationType.KYCVerified => "fa-solid fa-id-card",
                        NotificationType.CreditEvaluated => "fa-solid fa-gauge-high",
                        _ => "fa-solid fa-envelope"
                    };

                    <div class="list-group-item p-4 @bgClass">
                        <div class="d-flex gap-3 align-items-start">
                            <div class="@badgeColor bg-opacity-10 text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                                 style="width: 44px; height: 44px; background-color: rgba(var(--bs-primary-rgb), 0.1) !important; color: var(--bs-primary) !important;">
                                <i class="@iconClass" style="color: inherit;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-bold text-dark">
                                        @notif.Title 
                                        @if (!notif.IsRead)
                                        {
                                            <span class="badge bg-primary rounded-pill ms-2" style="font-size: 0.6rem;">NEW</span>
                                        }
                                    </span>
                                    <small class="text-muted text-nowrap ms-2">@notif.CreatedDate.ToString("dd MMM yyyy HH:mm")</small>
                                </div>
                                <p class="mb-0 text-muted small">@notif.Message</p>
                                
                                @if (notif.RelatedApplicationId > 0)
                                {
                                    <div class="mt-2">
                                        <span class="text-muted small">Related Application: </span>
                                        <span class="fw-semibold text-primary small">LOC-@notif.RelatedApplicationId</span>
                                    </div>
                                }
                            </div>
                            @if (!notif.IsRead)
                            {
                                <form asp-controller="Notification" asp-action="MarkRead" asp-route-id="@notif.NotificationId" method="post" class="ms-2">
                                    <button type="submit" class="btn btn-sm btn-link text-primary p-0 text-decoration-none" title="Mark Read">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-bell-slash text-muted fs-2 mb-3 d-block"></i>
                    <p class="text-muted">You have no notifications.</p>
                </div>
            }
        </div>
    </div>
</div>
