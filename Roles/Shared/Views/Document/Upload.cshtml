@{
    ViewData["Title"] = "Upload Documents";
    ViewData["CurrentStep"] = "Document Upload";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Document Upload Center</h1>
        <p class="text-muted">Upload and manage supporting documents for Loan Application: <strong>LOC-9844-32</strong></p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold m-0">Upload Application Documents</h5>
            </div>
            <div class="card-body">
                <!-- Drag and Drop Zone -->
                <div class="drag-drop-zone" id="dropZone">
                    <div class="drag-drop-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                    <h6 class="fw-bold text-dark mb-1">Drag & Drop Files Here</h6>
                    <p class="text-muted small mb-3">PDF, JPG, PNG — Max 10 MB per file</p>
                    <label class="btn btn-outline-primary btn-sm px-3" for="fileInput">
                        <i class="fa-solid fa-folder-open me-2"></i> Browse Files
                    </label>
                    <input type="file" id="fileInput" class="d-none" multiple accept=".pdf,.jpg,.jpeg,.png" />
                </div>

                <!-- Category Selector -->
                <div class="mt-3">
                    <label class="form-label fw-semibold text-muted small">Document Category</label>
                    <select class="form-select py-2 shadow-none" id="docCategory">
                        <option value="identity">Identity Proof (PAN/Aadhaar)</option>
                        <option value="income">Income Proof (Salary Slips)</option>
                        <option value="bank">Bank Statement (Last 6 Months)</option>
                        <option value="property">Property Documents (Title Deed)</option>
                        <option value="employer">Employer Letter</option>
                    </select>
                </div>

                <!-- Uploaded Files List -->
                <div id="uploadedFilesList" class="mt-4 d-flex flex-column gap-3">
                    <!-- Files rendered by document-upload.js -->
                </div>

                <div class="mt-4 d-flex gap-2" id="submitDocWrapper">
                    <button class="btn btn-success px-4 py-2 d-none" id="btnSubmitDocuments" onclick="finalizeDocuments()">
                        <i class="fa-solid fa-check-circle me-2"></i> Finalize & Proceed to Validation
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel - Required Docs Checklist -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold m-0">Required Document Checklist</h6>
            </div>
            <div class="card-body pt-0">
                <ul class="list-group list-group-flush" style="font-size: 0.875rem;" id="docChecklist">
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-id-card text-primary me-2"></i> Identity Proof (1 of 2)</div>
                        <span class="badge-status badge-status-pending" id="chk-identity">Required</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-receipt text-primary me-2"></i> Last 3 Salary Slips</div>
                        <span class="badge-status badge-status-pending" id="chk-income">Required</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-building-columns text-primary me-2"></i> Bank Statements (6 Mo.)</div>
                        <span class="badge-status badge-status-pending" id="chk-bank">Required</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-house-flag text-primary me-2"></i> Property Title Documents</div>
                        <span class="badge-status badge-status-pending" id="chk-property">Required</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-briefcase text-primary me-2"></i> Employer Letter</div>
                        <span class="badge-status badge-status-pending" id="chk-employer">Optional</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/document-upload.js"></script>
}
