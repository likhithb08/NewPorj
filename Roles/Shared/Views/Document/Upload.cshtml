@{
    ViewData["Title"] = "Upload Documents";
    ViewData["CurrentStep"] = "Document Upload";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Document Upload Center</h1>
        <p class="text-muted">Upload and manage supporting documents for Loan Application: <strong>LOC-9844-32</strong></p>
    </div>
</div>

@await Html.PartialAsync("_WorkflowStepper")

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="card-title fw-bold m-0">Uploaded Application Documents</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                        <div><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">PAN_Card_Rajesh_Kumar.pdf</span><span class="text-muted small ms-2">Identity Proof · 245 KB</span></div>
                        <span class="badge bg-success">Uploaded</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                        <div><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Salary_Slips_Jan-Mar_2026.pdf</span><span class="text-muted small ms-2">Income Proof · 1.2 MB</span></div>
                        <span class="badge bg-success">Uploaded</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                        <div><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Bank_Statement_6Months.pdf</span><span class="text-muted small ms-2">Bank Statement · 890 KB</span></div>
                        <span class="badge bg-success">Uploaded</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                        <div><i class="fa-solid fa-file-pdf text-danger me-2"></i><span class="fw-semibold">Property_Title_Deed.pdf</span><span class="text-muted small ms-2">Property Documents · 2.1 MB</span></div>
                        <span class="badge bg-success">Uploaded</span>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <a href="/Document/Validate/9844" class="btn btn-success px-4 py-2"><i class="fa-solid fa-check-circle me-2"></i> Application Submitted for Validation</a>
                    <a href="/Dashboard" class="btn btn-outline-secondary px-4 py-2">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold m-0">Required Document Checklist</h6>
            </div>
            <div class="card-body pt-0">
                <ul class="list-group list-group-flush" style="font-size: 0.875rem;">
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-id-card text-primary me-2"></i> Identity Proof (1 of 2)</div>
                        <span class="badge-status badge-status-approved">Verified</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-receipt text-primary me-2"></i> Last 3 Salary Slips</div>
                        <span class="badge-status badge-status-approved">Verified</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-building-columns text-primary me-2"></i> Bank Statements (6 Mo.)</div>
                        <span class="badge-status badge-status-approved">Verified</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-house-flag text-primary me-2"></i> Property Title Documents</div>
                        <span class="badge-status badge-status-approved">Verified</span>
                    </li>
                    <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                        <div><i class="fa-solid fa-briefcase text-primary me-2"></i> Employer Letter</div>
                        <span class="badge-status badge-status-pending">Optional</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
