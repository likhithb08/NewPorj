@{
    ViewData["Title"] = "Account Settings";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Account Settings</h1>
        <p class="text-muted">Manage your personal profile information, credentials, and notification preferences.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column - Profile summary info card -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm text-center py-4">
            <div class="card-body">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px; font-weight: 700; font-size: 2rem;" id="settingsInitials">
                    LO
                </div>
                <h5 class="fw-bold text-dark mb-1" id="settingsName">Likhith Kumar</h5>
                <p class="badge bg-light text-secondary border px-3 py-2 fw-semibold mb-3" id="settingsRole">Loan Officer</p>
                
                <div class="border-top pt-3 text-start small mt-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Account Status:</span>
                        <span class="text-success fw-bold">Active</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Location:</span>
                        <span class="fw-semibold text-dark">Bangalore HQ</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Member Since:</span>
                        <span class="fw-semibold text-dark">Jan 2024</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column - Profile forms -->
    <div class="col-lg-8">
        <!-- Personal Information form -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-user text-primary me-2"></i> Personal Profile Information</h6>
            </div>
            <div class="card-body">
                <form id="profileInfoForm" onsubmit="saveProfileInfo(event)">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Full Name</label>
                            <input type="text" class="form-control py-2 shadow-none" id="profileFullName" value="Likhith Kumar" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Email Address</label>
                            <input type="email" class="form-control py-2 shadow-none" id="profileEmail" value="likhith.k@locps.in" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Phone Number</label>
                            <input type="tel" class="form-control py-2 shadow-none" id="profilePhone" value="+91 98765 01234" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Branch Office</label>
                            <input type="text" class="form-control py-2 shadow-none" id="profileBranch" value="Bangalore Main Branch" readonly />
                        </div>
                    </div>
                    <div class="mt-4 pt-2">
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: var(--radius-md);">Save Profile Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Password Change form -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-lock text-primary me-2"></i> Security & Password Management</h6>
            </div>
            <div class="card-body">
                <form id="passwordForm" onsubmit="changePassword(event)">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold text-muted small">Current Password</label>
                            <input type="password" class="form-control py-2 shadow-none" id="currentPass" required placeholder="••••••••" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">New Password</label>
                            <input type="password" class="form-control py-2 shadow-none" id="newPass" required placeholder="New password" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Confirm New Password</label>
                            <input type="password" class="form-control py-2 shadow-none" id="confirmNewPass" required placeholder="Confirm new password" />
                        </div>
                    </div>
                    <div class="mt-4 pt-2">
                        <button type="submit" class="btn btn-dark px-4" style="border-radius: var(--radius-md);">Change Password</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Notification Preferences -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 border-bottom">
                <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-bell text-primary me-2"></i> Notification Configurations</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h6 class="fw-semibold text-dark mb-0 small">Email Notifications</h6>
                        <span class="text-muted small">Receive automatic emails for transaction receipts and application status checks.</span>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" checked onchange="showToast('Setting Saved','Email alert preferences updated.','success')" />
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h6 class="fw-semibold text-dark mb-0 small">In-App Toast Alerts</h6>
                        <span class="text-muted small">Display slide-in toast updates when scoring rules are complete or applications forward.</span>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" checked onchange="showToast('Setting Saved','In-app toast preferences updated.','success')" />
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-semibold text-dark mb-0 small">SMS Reminders</h6>
                        <span class="text-muted small">Send text notification warnings for critical underwriter actions.</span>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" onchange="showToast('Setting Saved','SMS reminder preferences updated.','success')" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Load current role from storage to set display details
            const role = localStorage.getItem("locps_demo_role") || "officer";
            const roleProfiles = {
                customer: { name: "Rajesh Kumar", role: "Portal Customer", initials: "RK", email: "customer@locps.in", phone: "+91 98765 43210", location: "Bangalore Retail" },
                officer: { name: "Likhith Kumar", role: "Loan Officer", initials: "LO", email: "likhith.k@locps.in", phone: "+91 98765 01234", location: "Bangalore HQ" },
                underwriter: { name: "Anjali Sharma", role: "Senior Underwriter", initials: "UW", email: "anjali.s@locps.in", phone: "+91 98765 99881", location: "Bangalore HQ" },
                admin: { name: "System Administrator", role: "Super Admin", initials: "SA", email: "admin@locps.in", phone: "+91 98765 55667", location: "Main Center" }
            };

            const prof = roleProfiles[role];
            if (prof) {
                document.getElementById("settingsInitials").textContent = prof.initials;
                document.getElementById("settingsName").textContent = prof.name;
                document.getElementById("settingsRole").textContent = prof.role;
                
                document.getElementById("profileFullName").value = prof.name;
                document.getElementById("profileEmail").value = prof.email;
                document.getElementById("profilePhone").value = prof.phone;
                document.getElementById("profileBranch").value = prof.location;
            }
        });

        function saveProfileInfo(e) {
            e.preventDefault();
            const newName = document.getElementById("profileFullName").value.trim();
            document.getElementById("settingsName").textContent = newName;
            if (window.logWorkflowAction) {
                window.logWorkflowAction("Profile Updates", "User Profile Settings");
            }
            showToast("Profile Updated", "Personal profile details updated successfully.", "success");
        }

        function changePassword(e) {
            e.preventDefault();
            const currentPass = document.getElementById("currentPass").value;
            const newPass = document.getElementById("newPass").value;
            const confirmNewPass = document.getElementById("confirmNewPass").value;

            if (newPass !== confirmNewPass) {
                showToast("Password Mismatch", "New passwords do not match. Please re-enter.", "warning");
                return;
            }

            document.getElementById("currentPass").value = "";
            document.getElementById("newPass").value = "";
            document.getElementById("confirmNewPass").value = "";

            if (window.logWorkflowAction) {
                window.logWorkflowAction("Profile Updates", "Security Settings");
            }
            showToast("Password Updated", "Your account security password has been changed.", "success");
        }
    </script>
}
