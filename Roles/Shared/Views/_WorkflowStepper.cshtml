@{
    var steps = new[] {
        "Submission", 
        "Verification", 
        "Credit Scoring", 
        "Underwriting", 
        "Disbursement"
    };
    var currentStep = ViewData["CurrentStep"] as string ?? "";
    var currentIndex = 0; // Default to first step
    
    if (!string.IsNullOrEmpty(currentStep)) {
        var lowerStep = currentStep.ToLower();
        if (lowerStep.Contains("registration") || lowerStep.Contains("loan") || lowerStep.Contains("upload") || lowerStep.Contains("submission")) {
            currentIndex = 0;
        }
        else if (lowerStep.Contains("kyc") || lowerStep.Contains("verify") || lowerStep.Contains("validate") || lowerStep.Contains("verification")) {
            currentIndex = 1;
        }
        else if (lowerStep.Contains("credit") || lowerStep.Contains("evaluate") || lowerStep.Contains("score") || lowerStep.Contains("scoring")) {
            currentIndex = 2;
        }
        else if (lowerStep.Contains("review") || lowerStep.Contains("approval") || lowerStep.Contains("decision") || lowerStep.Contains("approve") || lowerStep.Contains("reject") || lowerStep.Contains("underwrite")) {
            currentIndex = 3;
        }
        else if (lowerStep.Contains("disburse") || lowerStep.Contains("disbursement") || lowerStep.Contains("complete") || lowerStep.Contains("history")) {
            currentIndex = 4;
        }
    }
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-4">
        <div class="stepper-container">
            <div class="stepper" style="min-width: auto;">
                @for (int i = 0; i < steps.Length; i++)
                {
                    var stepClass = "";
                    var iconHtml = "";
                    
                    if (i < currentIndex) 
                    {
                        stepClass = "completed";
                        iconHtml = "<i class=\"fa-solid fa-check fs-6\"></i>";
                    }
                    else if (i == currentIndex) 
                    {
                        stepClass = "active";
                        iconHtml = $"<span class=\"fw-bold\">{i + 1}</span>";
                    }
                    else 
                    {
                        stepClass = "text-muted";
                        iconHtml = $"<span>{i + 1}</span>";
                    }

                    <div class="step-item @stepClass">
                        <div class="step-circle">@Html.Raw(iconHtml)</div>
                        <div class="step-label">@steps[i]</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
